---
export interface Props {
    phase: string;
    title: string;
    status?: "done" | "planned" | "dream";
}

const { phase, title, status = "done" } = Astro.props;

const statusMeta: Record<string, { label: string; icon: string }> = {
    done: {
        label: "Réalisé",
        icon: `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
    },
    planned: {
        label: "Planifié",
        icon: `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>`,
    },
    dream: {
        label: "Vision",
        icon: `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
    },
};

const { label, icon } = statusMeta[status] ?? statusMeta.done;
---

<div class={`timeline-step timeline-step--${status}`}>
    <div class="step-marker" aria-hidden="true">
        <div class="step-dot-wrap">
            {status === "done" && <span class="step-dot-ring" />}
            <span class="step-dot"></span>
        </div>
        <span class="step-line"></span>
    </div>

    <div class="step-content">
        <header class="step-header">
            <span class="step-phase">{phase}</span>
            <span class="step-badge">
                <span class="badge-icon" set:html={icon} />
                <span class="badge-label">{label}</span>
            </span>
        </header>

        <h3 class="step-title">{title}</h3>

        <div class="step-card">
            <div class="step-card-glow" aria-hidden="true"></div>
            <div class="step-body">
                <slot />
            </div>
        </div>
    </div>
</div>

<style>
    .timeline-step {
        display: grid;
        grid-template-columns: 2rem 1fr;
        gap: 0 1.25rem;
        margin-bottom: 0;
    }

    .timeline-step :is(h1, h2, h3, h4, h5, h6) {
        animation: none !important;
    }

    .step-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 0.15rem;
    }

    .step-dot-wrap {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .step-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 1.5px solid var(--color-border);
        background: var(--color-bg);
        position: relative;
        z-index: 1;
        flex-shrink: 0;
    }

    .step-dot-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(var(--accent), 0.15);
        animation: dot-pulse 2.8s ease-in-out infinite;
    }

    @keyframes dot-pulse {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.6;
        }
        50% {
            transform: scale(1.6);
            opacity: 0;
        }
    }

    .timeline-step--done .step-dot {
        background: var(--color-accent);
        border-color: var(--color-accent);
        box-shadow:
            0 0 0 3px rgba(var(--accent), 0.15),
            0 0 8px rgba(var(--accent), 0.3);
    }

    .timeline-step--planned .step-dot {
        border-color: var(--tint-20);
        background: var(--tint-05);
    }

    .timeline-step--dream .step-dot {
        border-color: var(--tint-10);
        opacity: 0.4;
    }

    .step-line {
        flex: 1;
        width: 1px;
        margin-top: 4px;
        min-height: 2rem;
        background: linear-gradient(to bottom, var(--tint-20), var(--tint-05));
    }

    .timeline-step--planned .step-line,
    .timeline-step--dream .step-line {
        background: linear-gradient(to bottom, var(--tint-10), transparent);
    }

    .timeline-step:last-child .step-line {
        display: none;
    }

    .step-content {
        padding-bottom: 2.5rem;
    }

    .step-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
        padding-top: 0.1rem;
    }

    .step-phase {
        font-family: var(--font-title);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--color-accent);
    }

    .timeline-step--planned .step-phase {
        color: var(--color-muted);
    }
    .timeline-step--dream .step-phase {
        color: var(--color-muted);
        opacity: 0.6;
    }

    .step-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.2rem 0.65rem;
        border-radius: 999px;
        border: 1px solid var(--color-border);
        background: var(--tint-05);
        font-family: var(--font-title);
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--color-muted);
    }

    .timeline-step--done .step-badge {
        border-color: rgba(var(--accent), 0.2);
        background: rgba(var(--accent), 0.05);
        color: var(--color-accent);
    }

    .badge-icon {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        opacity: 0.9;
    }

    .step-title {
        font-family: var(--font-title);
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin: 0 0 1rem;
        line-height: 1.3;
    }

    .timeline-step--planned .step-title,
    .timeline-step--dream .step-title {
        opacity: 0.45;
    }

    .step-card {
        position: relative;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 1.25rem 1.5rem;
        overflow: hidden;
        isolation: isolate;
        background: var(--color-surface);
        box-shadow: var(--shadow-soft);
        transition:
            box-shadow var(--duration-base) ease,
            border-color var(--duration-base) ease;
    }

    .timeline-step--done .step-card {
        border-color: var(--color-border);
    }

    .timeline-step--planned .step-card,
    .timeline-step--dream .step-card {
        opacity: 0.55;
    }

    .timeline-step--done .step-card:hover {
        border-color: rgba(var(--accent), 0.2);
        box-shadow: var(--shadow-strong);
    }

    .step-card-glow {
        position: absolute;
        inset: 0;
        pointer-events: none;
        border-radius: inherit;
        background: radial-gradient(
            ellipse at 0% 0%,
            rgba(var(--accent), 0.06) 0%,
            transparent 65%
        );
        opacity: 0;
        transition: opacity var(--duration-base) ease;
    }

    .timeline-step--done .step-card:hover .step-card-glow {
        opacity: 1;
    }

    .step-body {
        position: relative;
        z-index: 1;
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--color-muted);
    }

    .step-body :global(p) {
        margin: 0 0 0.6rem;
    }
    .step-body :global(p:last-child) {
        margin-bottom: 0;
    }
    .step-body :global(strong) {
        color: var(--color-text);
        font-weight: 600;
    }

    @media (max-width: 640px) {
        .timeline-step {
            grid-template-columns: 1.75rem 1fr;
            gap: 0 1rem;
        }
        .step-card {
            padding: 1rem 1.25rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .step-dot-ring {
            animation: none;
            opacity: 0.4;
        }
    }
</style>
