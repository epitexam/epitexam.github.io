---
export interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
---

<article class="expertise-card">
    <div class="card-glow" aria-hidden="true"></div>
    <div class="card-inner">
        <h3 class="card-title">{title}</h3>
        <p class="card-desc">{description}</p>
    </div>
</article>

<style>
    .expertise-card {
        position: relative;
        padding: 1.5rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        isolation: isolate;
        box-shadow: var(--shadow-soft);
        transition:
            border-color var(--duration-base) var(--ease-spring),
            box-shadow var(--duration-base) var(--ease-spring),
            transform var(--duration-base) var(--ease-spring);
    }

    .expertise-card :is(h1, h2, h3, h4, h5, h6) {
        animation: none !important;
    }

    .expertise-card:hover {
        transform: translateY(-2px);
        border-color: rgba(var(--accent), 0.25);
        box-shadow: var(--shadow-strong);
    }

    .card-glow {
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        background: radial-gradient(
            ellipse at 0% 0%,
            rgba(var(--accent), 0.08) 0%,
            transparent 60%
        );
        opacity: 0;
        z-index: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) ease;
    }

    .expertise-card:hover .card-glow {
        opacity: 1;
    }

    .card-inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .card-title {
        font-family: var(--font-title);
        font-size: 1.05rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin: 0;
        line-height: 1.3;
        transition: color var(--duration-fast) ease;
    }

    .expertise-card:hover .card-title {
        color: var(--color-accent);
    }

    .card-desc {
        font-size: 0.9rem;
        line-height: 1.65;
        color: var(--color-muted);
        margin: 0;
    }

    @media (max-width: 640px) {
        .expertise-card {
            padding: 1.25rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .expertise-card:hover {
            transform: none;
        }
    }
</style>
