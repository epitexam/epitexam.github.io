---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";
import fallBackImage from "../assets/sejio.webp";

interface Props {
    project: CollectionEntry<"projects">;
    index: number;
    headingLevel?: "h2" | "h3";
}

const { project, index, headingLevel = "h3" } = Astro.props;
const { data, id } = project;
const isEager = index < 2;

const imageSrc = data.heroImage ?? fallBackImage;
const imageAlt = data.heroImageDescription || data.title;
const HeadingTag = headingLevel;

const IMG_W = 800;
const IMG_H = 450;
---

<article class:list={["project-card", { featured: data.featured }]}>
    <a
        href={`/project/${id}/`}
        class="image-link"
        tabindex="-1"
        aria-hidden="true"
    >
        <Image
            src={imageSrc}
            alt={imageAlt}
            class="card-img"
            loading={isEager ? "eager" : "lazy"}
            fetchpriority={isEager ? "high" : "auto"}
            widths={[400, 600, 800]}
            sizes="(max-width: 480px) 100vw, (max-width: 768px) 600px, 400px"
            width={IMG_W}
            height={IMG_H}
            quality={65}
            format="webp"
        />
    </a>

    <div class="card-content">
        <header class="card-header">
            <div class="card-eyebrow">
                <FormattedDate date={data.pubDate} />
                {
                    data.featured && (
                        <span
                            class="featured-badge"
                            aria-label="Projet mis en avant"
                        >
                            <span class="featured-dot" aria-hidden="true" />
                            Featured
                        </span>
                    )
                }
            </div>

            <HeadingTag class="project-title">
                <a href={`/project/${id}/`} class="title-link">
                    {data.title}
                </a>
            </HeadingTag>

            <p class="desc">{data.description}</p>
        </header>

        {
            data.technologies.length > 0 && (
                <ul class="tech-stack" aria-label="Technologies utilisées">
                    {data.technologies.slice(0, 4).map((tech) => (
                        <li class="tech-tag">{tech}</li>
                    ))}
                </ul>
            )
        }

        <footer class="card-actions">
            <a
                href={`/project/${id}/`}
                class="btn btn-primary"
                aria-label={`Voir les détails de ${data.title}`}
            >
                Détails
            </a>

            {
                (data.liveUrl || data.sourceUrl) && (
                    <div class="external-links">
                        {data.liveUrl && (
                            <a
                                href={data.liveUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-ghost"
                                aria-label={`Voir la démo en ligne de ${data.title}`}
                            >
                                Live
                                <svg
                                    width="9"
                                    height="9"
                                    viewBox="0 0 12 12"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M1 11L11 1M11 1H1M11 1V11"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                            </a>
                        )}
                        {data.sourceUrl && (
                            <a
                                href={data.sourceUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-ghost"
                                aria-label={`Voir le code source de ${data.title}`}
                            >
                                Code
                                <svg
                                    width="9"
                                    height="9"
                                    viewBox="0 0 12 12"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M1 11L11 1M11 1H1M11 1V11"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                            </a>
                        )}
                    </div>
                )
            }
        </footer>
    </div>
</article>

<style>
    .project-card {
        background: rgba(var(--bg, 9, 9, 9), 0.9);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        transition:
            transform var(--duration-base) var(--ease-spring),
            border-color var(--duration-base) ease,
            box-shadow var(--duration-base) ease;
    }

    .project-card :is(h1, h2, h3, h4, h5, h6) {
        animation: none !important;
    }

    .project-card ul,
    .project-card ol {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .project-card li::before,
    .project-card li::after {
        content: none !important;
        display: none;
    }

    @media (hover: hover) {
        .project-card:hover {
            transform: translateY(-3px);
            border-color: var(--accent-40);
            box-shadow: var(--shadow-strong);
        }
    }

    .project-card.featured {
        border-color: var(--accent-20);
    }

    .image-link {
        display: block;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surface);
        background-image: radial-gradient(
            rgba(var(--text, 232, 232, 234), 0.06) 1px,
            transparent 1px
        );
        background-size: 20px 20px;
    }

    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%);
        transition:
            transform var(--duration-slow) var(--ease-spring),
            filter var(--duration-base) ease;
    }

    @media (hover: hover) {
        .project-card:hover .card-img {
            transform: scale(1.04);
            filter: grayscale(0%);
        }
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: 1rem;
    }

    .card-eyebrow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-title);
        font-size: 0.65rem;
        color: var(--color-muted);
        letter-spacing: 0.06em;
        margin-bottom: 0.4rem;
    }

    .featured-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.25rem 0.65rem 0.25rem 0.45rem;
        background: rgba(var(--badge-green-rgb, 34, 197, 94), 0.12);
        border: 1.5px solid rgba(var(--badge-green-rgb, 34, 197, 94), 0.35);
        border-radius: 999px;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgb(var(--badge-green-rgb, 34, 197, 94));
    }

    .featured-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 6px rgba(var(--badge-green-rgb, 34, 197, 94), 0.7);
        animation: dot-pulse 2.5s ease-in-out infinite;
    }

    @keyframes dot-pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.3;
        }
    }

    .project-title {
        margin: 0 0 0.5rem;
        padding: 0;
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.025em;
        color: var(--color-text);
    }

    .title-link {
        text-decoration: none;
        color: inherit;
        transition: color var(--duration-fast) ease;
    }

    @media (hover: hover) {
        .title-link:hover {
            color: var(--color-accent);
        }
    }

    .desc {
        font-size: 0.875rem;
        color: var(--color-muted);
        line-height: 1.55;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: auto;
    }

    .tech-tag {
        font-size: 0.62rem;
        font-weight: 700;
        padding: 0.2rem 0.55rem;
        background: var(--accent-05);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        color: var(--color-muted);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        transition:
            border-color var(--duration-fast) ease,
            color var(--duration-fast) ease;
    }

    @media (hover: hover) {
        .project-card:hover .tech-tag {
            border-color: var(--accent-20);
            color: var(--color-text);
        }
    }

    .card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
    }

    .external-links {
        display: flex;
        gap: 0.5rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1.1rem;
        border-radius: 999px;
        border: 1.5px solid transparent;
        backdrop-filter: blur(10px) saturate(160%);
        -webkit-backdrop-filter: blur(10px) saturate(160%);

        font-family: var(--font-title);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;

        transition: all var(--duration-base) var(--ease-spring);
    }

    .btn-primary {
        background: rgba(var(--text, 232, 232, 234), 0.1);
        border-color: rgba(var(--text, 232, 232, 234), 0.35);
        color: var(--color-text);
    }

    @media (hover: hover) {
        .btn-primary:hover {
            transform: translateY(-2px);
            background: rgba(var(--text, 232, 232, 234), 0.18);
            border-color: rgba(var(--text, 232, 232, 234), 0.6);
            box-shadow: 0 4px 12px rgba(var(--text, 232, 232, 234), 0.12);
        }
    }

    .btn-ghost {
        padding: 0.45rem 0.9rem 0.45rem 0.75rem;
        background: rgba(var(--text, 232, 232, 234), 0.04);
        border-color: rgba(var(--text, 232, 232, 234), 0.18);
        color: var(--color-muted);
    }

    @media (hover: hover) {
        .btn-ghost:hover {
            transform: translateY(-2px);
            background: rgba(var(--text, 232, 232, 234), 0.1);
            border-color: rgba(var(--text, 232, 232, 234), 0.4);
            color: var(--color-text);
            box-shadow: 0 4px 12px rgba(var(--text, 232, 232, 234), 0.08);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .featured-dot {
            animation: none;
        }

        .project-card,
        .btn {
            transition: none;
        }
    }
</style>