---
import { Image } from "astro:assets";
import Tag from "./Tag.astro";

interface Props {
    rank: number;
    title: string;
    slug: string;
    image: string;
    imageAlt: string;
    developer: string;
    publisher?: string;
    engine?: string;
    releaseDate: string;
    genre: string;
    platforms: string[];
    storeUrl?: string;
    playtime?: string;
    description: string;
    summary: string;
    pros: string[];
    cons: string[];
    linux: string;
    rankingReason: string;
    tags?: string[];
}

const game = Astro.props;
const isTopOne = game.rank === 1;
---

<article
    class:list={["game-card", { "top-one": isTopOne }]}
    itemscope
    itemtype="https://schema.org/VideoGame"
    id={game.slug}
>
    <div class="rank-badge">
        <span class="rank-number">#{game.rank}</span>
        {
            isTopOne && (
                <span class="crown-icon" aria-label="Coup de cœur">
                    👑
                </span>
            )
        }
    </div>

    <header class="game-header">
        {
            isTopOne && (
                <div class="top-one-badge">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true"
                    >
                        <path
                            d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                            fill="currentColor"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linejoin="round"
                        />
                    </svg>
                    <span>Coup de cœur 2025</span>
                </div>
            )
        }
        <h2 class="game-title" itemprop="name">{game.title}</h2>
        <p class="game-description" itemprop="description">
            {game.description}
        </p>
    </header>

    <figure class="game-image">
        <Image
            src={game.image}
            alt={game.imageAlt}
            width={1200}
            height={600}
            loading="lazy"
            class="game-img"
        />
    </figure>

    <section class="game-meta">
        <div class="meta-grid">
            <div class="meta-item">
                <span class="meta-label">Développeur</span>
                <span class="meta-value" itemprop="author"
                    >{game.developer}</span
                >
            </div>
            {
                game.publisher && (
                    <div class="meta-item">
                        <span class="meta-label">Éditeur</span>
                        <span class="meta-value">{game.publisher}</span>
                    </div>
                )
            }
            <div class="meta-item">
                <span class="meta-label">Sortie</span>
                <time
                    class="meta-value"
                    itemprop="datePublished"
                    datetime={game.releaseDate}
                >
                    {
                        new Date(game.releaseDate).toLocaleDateString("fr-FR", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
            </div>
            <div class="meta-item">
                <span class="meta-label">Genre</span>
                <span class="meta-value" itemprop="genre">{game.genre}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Plateformes</span>
                <span class="meta-value">{game.platforms.join(", ")}</span>
            </div>
            {
                game.engine && (
                    <div class="meta-item">
                        <span class="meta-label">Moteur</span>
                        <span class="meta-value">{game.engine}</span>
                    </div>
                )
            }
            {
                game.playtime && (
                    <div class="meta-item">
                        <span class="meta-label">Temps de jeu</span>
                        <span class="meta-value">{game.playtime}</span>
                    </div>
                )
            }
            {
                game.storeUrl && (
                    <div class="meta-item">
                        <span class="meta-label">Boutique</span>
                        <a
                            href={game.storeUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="store-link"
                        >
                            Voir sur Steam
                            <svg
                                width="13"
                                height="13"
                                viewBox="0 0 24 24"
                                fill="none"
                                aria-hidden="true"
                            >
                                <path
                                    d="M7 17L17 7M17 7H7M17 7V17"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                />
                            </svg>
                        </a>
                    </div>
                )
            }
        </div>
    </section>

    <section class="game-content">
        <div class="content-block">
            <h3>En quelques mots</h3>
            <p>{game.summary}</p>
        </div>

        <div class="content-columns">
            <div class="content-block">
                <h3>Points forts</h3>
                <ul class="pros-list">
                    {
                        game.pros.map((pro) => (
                            <li>
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M20 6L9 17l-5-5"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                                <span>{pro}</span>
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div class="content-block">
                <h3>Points faibles</h3>
                <ul class="cons-list">
                    {
                        game.cons.map((con) => (
                            <li>
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M18 6L6 18M6 6l12 12"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                                <span>{con}</span>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>

        <div class="content-block">
            <h3>Expérience Linux</h3>
            <p>{game.linux}</p>
        </div>

        <div class="content-block highlight-block">
            <h3>Pourquoi ce classement</h3>
            <p>{game.rankingReason}</p>
        </div>
    </section>

    {
        game.tags && game.tags.length > 0 && (
            <footer class="game-footer">
                <div class="game-tags">
                    {game.tags.map((tag) => (
                        <Tag tag={tag} />
                    ))}
                </div>
            </footer>
        )
    }
</article>

<style>
    ul,
    ol,
    li {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    li::before,
    li::after {
        content: none !important;
        display: none !important;
    }

    .game-card {
        position: relative;
        margin: 0 0 5rem;
        padding: 2.5rem;
        background: rgba(var(--bg), 0.9);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        transition:
            border-color var(--duration-base) ease,
            box-shadow var(--duration-base) ease;
    }

    .game-card:hover {
        border-color: var(--accent-40);
        box-shadow: var(--shadow-strong);
    }

    .game-card.top-one {
        border: 2px solid var(--accent-20);
    }

    .game-card.top-one:hover {
        border-color: var(--accent-40);
    }

    .rank-badge {
        position: absolute;
        top: -1rem;
        left: 2rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 1.1rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 999px;
    }

    .rank-number {
        font-family: var(--font-title);
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: -0.02em;
    }

    .crown-icon {
        font-size: 1rem;
        line-height: 1;
    }

    .top-one-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        background: rgba(var(--accent), 0.06);
        border: 1px solid rgba(var(--accent), 0.2);
        border-radius: 999px;
        font-family: var(--font-title);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--color-accent);
        margin-bottom: 1rem;
        text-transform: uppercase;
    }

    .game-header {
        margin-bottom: 2rem;
    }

    .game-title {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 800;
        margin: 0 0 1rem;
        color: var(--color-text);
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    .game-description {
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--color-muted);
        max-width: 800px;
    }

    .game-image {
        margin: 0 0 2.5rem;
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-soft);
        background: var(--color-surface);
        background-image: radial-gradient(
            rgba(var(--text), 0.05) 1px,
            transparent 1px
        );
        background-size: 20px 20px;
    }

    .game-img {
        width: 100%;
        height: auto;
        object-fit: cover;
        display: block;
        filter: grayscale(10%);
        transition:
            transform var(--duration-base) var(--ease-spring),
            filter var(--duration-base) ease;
    }

    .game-card:hover .game-img {
        transform: scale(1.01);
        filter: grayscale(0%);
    }

    .game-meta {
        margin-bottom: 2.5rem;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.25rem;
        padding: 1.5rem;
        background: var(--accent-05);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .meta-label {
        font-family: var(--font-title);
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--color-muted);
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .meta-value {
        font-size: 0.9rem;
        color: var(--color-text);
        line-height: 1.5;
    }

    .store-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.9rem;
        color: var(--color-accent);
        font-weight: 500;
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .store-link:hover {
        color: var(--color-text);
    }

    .game-content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .content-block h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 0.9rem;
        color: var(--color-text);
        letter-spacing: -0.02em;
        animation: none;
    }

    .content-block p {
        font-size: 0.975rem;
        line-height: 1.7;
        color: var(--color-muted);
    }

    .content-columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .pros-list,
    .cons-list {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .pros-list li,
    .cons-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 0.5rem 0.75rem;
        background: var(--accent-05);
        border: 1px solid transparent;
        border-radius: var(--radius-sm);
        transition:
            background var(--duration-fast) ease,
            border-color var(--duration-fast) ease;
    }

    .pros-list li:hover,
    .cons-list li:hover {
        background: var(--accent-10);
        border-color: var(--color-border);
    }

    .pros-list svg {
        color: var(--color-accent);
        flex-shrink: 0;
        margin-top: 0.2rem;
    }
    .cons-list svg {
        color: var(--color-muted);
        flex-shrink: 0;
        margin-top: 0.2rem;
        opacity: 0.5;
    }

    .pros-list span,
    .cons-list span {
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--color-muted);
    }

    .highlight-block {
        padding: 1.5rem;
        background: var(--accent-05);
        border-left: 2px solid var(--color-accent);
        border-radius: var(--radius-sm);
    }

    .highlight-block h3 {
        color: var(--color-accent);
    }

    /* ── Footer ── */
    .game-footer {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
    }

    .game-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .game-card {
            padding: 1.5rem;
            margin: 0 0 3rem;
        }
        .rank-badge {
            left: 1rem;
        }
        .meta-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
            padding: 1.25rem;
        }
        .content-columns {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        .highlight-block {
            padding: 1.25rem;
        }
    }

    @media (max-width: 480px) {
        .game-card {
            padding: 1.25rem;
        }
        .top-one-badge {
            font-size: 0.65rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .game-card:hover,
        .pros-list li:hover,
        .cons-list li:hover {
            transition: none;
        }
        .game-card:hover .game-img {
            transform: none;
        }
    }
</style>
