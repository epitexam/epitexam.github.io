---
interface Props {
    label: string;
    href?: string;
    linkText?: string;
    level?: "h1" | "h2" | "h3" | "h4";
    id?: string;
}

const { label, href, linkText, level = "h2", id } = Astro.props;
const HeadingTag = level;
---

<div class="section-header">
    <div class="section-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        <HeadingTag class="badge-label" id={id}>{label}</HeadingTag>
    </div>
    <span class="section-line" aria-hidden="true"></span>
    {
        href && linkText && (
            <a href={href} class="section-link">
                {linkText}
                <svg
                    class="arrow-icon"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    aria-hidden="true"
                >
                    <path
                        d="M6 12L10 8L6 4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    />
                </svg>
            </a>
        )
    }
</div>

<style>
    .section-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        width: 100%;
        padding-block: 1.5rem;
    }

    .section-header :is(h1, h2, h3, h4, h5, h6) {
        animation: none !important;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 1rem;
        background: var(--tint-05);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        font-family: var(--font-title);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--color-text);
        white-space: nowrap;
    }

    .badge-label {
        margin: 0;
        padding: 0;
        font-size: inherit;
        font-weight: inherit;
        font-family: inherit;
        line-height: inherit;
        color: inherit;
        letter-spacing: inherit;
    }

    .badge-dot {
        width: 6px;
        height: 6px;
        background: var(--color-accent);
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 8px rgba(var(--accent), 0.5);
    }

    .section-line {
        flex: 1;
        height: 1px;
        background: var(--tint-10);
    }

    .section-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-title);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-muted);
        text-decoration: none;
        white-space: nowrap;
        transition: color var(--duration-fast) ease;
    }

    .section-link:hover {
        color: var(--color-text);
    }

    .arrow-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        transition: transform var(--duration-base) var(--ease-spring);
    }

    .section-link:hover .arrow-icon {
        transform: translateX(4px);
    }

    @media (max-width: 768px) {
        .section-header {
            gap: 1rem;
        }
        .section-badge {
            padding: 0.35rem 0.85rem;
            font-size: 0.75rem;
        }
        .section-link {
            font-size: 0.75rem;
        }
    }

    @media (max-width: 600px) {
        .section-header {
            gap: 0.65rem;
        }
        .section-badge {
            font-size: 0.7rem;
            gap: 0.45rem;
        }
        .badge-dot {
            width: 5px;
            height: 5px;
        }
        .section-link {
            font-size: 0.7rem;
            gap: 0.35rem;
        }
        .arrow-icon {
            width: 14px;
            height: 14px;
        }
    }

    @media (max-width: 480px) {
        .section-header {
            justify-content: space-between;
            gap: 0.5rem;
        }
        .section-line {
            display: none;
        }
        .section-badge {
            font-size: 0.65rem;
            gap: 0.4rem;
        }
        .section-link {
            font-size: 0.65rem;
            gap: 0.3rem;
        }
        .arrow-icon {
            width: 12px;
            height: 12px;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .section-link:hover .arrow-icon {
            transform: none;
        }
    }
</style>
