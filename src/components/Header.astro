---
import { GITHUB_URL, SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const navLinks = [
    { href: "/", label: "Accueil" },
    { href: "/about", label: "À propos" },
    { href: "/tools", label: "Outils" },
    { href: "/blog", label: "Blog" },
    { href: "/project", label: "Projects" },
    { href: "/contact", label: "Contact" },
];
---

<header class="site-header">
    <div class="header-inner">
        <a href="/" class="brand-link">{SITE_TITLE}</a>

        <nav class="desktop-nav" aria-label="Navigation principale">
            {
                navLinks.map(({ href, label }) => (
                    <HeaderLink href={href}>{label}</HeaderLink>
                ))
            }
        </nav>

        <div class="header-right">
            <a
                href={GITHUB_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
                aria-label="Voir mon GitHub"
            >
                <svg
                    viewBox="0 0 16 16"
                    width="16"
                    height="16"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                    ></path>
                </svg>
            </a>

            <button
                id="menu-toggle"
                class="menu-toggle"
                aria-label="Ouvrir le menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>
        </div>
    </div>

    <nav
        id="mobile-menu"
        class="mobile-menu"
        aria-label="Navigation mobile"
        aria-hidden="true"
        inert
    >
        <div class="mobile-menu-inner">
            {
                navLinks.map(({ href, label }) => (
                    <HeaderLink href={href} class="mobile-link">
                        {label}
                    </HeaderLink>
                ))
            }
        </div>
    </nav>
</header>

<script>
    const toggle = document.getElementById(
        "menu-toggle",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById("mobile-menu") as HTMLElement | null;
    const header = document.querySelector<HTMLElement>(".site-header");

    if (!toggle || !menu || !header)
        throw new Error("Éléments du menu introuvables.");
    if (toggle.hasAttribute("data-menu-initialized"))
        throw new Error("Déjà initialisé.");
    toggle.setAttribute("data-menu-initialized", "true");

    const isOpen = () => toggle.getAttribute("aria-expanded") === "true";

    const open = () => {
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Fermer le menu");
        menu.setAttribute("aria-hidden", "false");
        menu.removeAttribute("inert");
        menu.classList.add("is-open");
        header.classList.add("menu-is-open");
    };

    const close = () => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Ouvrir le menu");
        menu.setAttribute("aria-hidden", "true");
        menu.setAttribute("inert", "");
        menu.classList.remove("is-open");
        header.classList.remove("menu-is-open");
    };

    const updateScrollState = () => {
        header.classList.toggle("is-scrolled", window.scrollY > 20);
    };
    updateScrollState();
    window.addEventListener("scroll", updateScrollState, { passive: true });

    const handleToggleClick = (e: MouseEvent) => {
        e.stopPropagation();
        isOpen() ? close() : open();
    };

    const handleLinkClick = () => close();

    const handleOutsideClick = (e: MouseEvent) => {
        const target = e.target as Node;
        if (isOpen() && !menu.contains(target) && !toggle.contains(target))
            close();
    };

    const mediaQuery = window.matchMedia("(min-width: 769px)");
    const handleMediaChange = (e: MediaQueryListEvent) => {
        if (e.matches) close();
    };

    const menuLinks = [...menu.querySelectorAll("a")];

    toggle.addEventListener("click", handleToggleClick);
    menuLinks.forEach((l) => l.addEventListener("click", handleLinkClick));
    document.addEventListener("click", handleOutsideClick);
    mediaQuery.addEventListener("change", handleMediaChange);

    window.addEventListener(
        "astro:before-swap",
        () => {
            toggle.removeEventListener("click", handleToggleClick);
            menuLinks.forEach((l) =>
                l.removeEventListener("click", handleLinkClick),
            );
            document.removeEventListener("click", handleOutsideClick);
            mediaQuery.removeEventListener("change", handleMediaChange);
            window.removeEventListener("scroll", updateScrollState);
            toggle.removeAttribute("data-menu-initialized");
        },
        { once: true },
    );
</script>

<style>
    .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(var(--bg), 0.96);
        border-bottom: 1px solid rgba(var(--text), 0.07);
        transition:
            background var(--duration-base) ease,
            border-color var(--duration-base) ease;
    }

    @supports (backdrop-filter: blur(1px)) {
        .site-header {
            background: rgba(var(--bg), 0.72);
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
        }

        .site-header.is-scrolled {
            background: rgba(var(--bg), 0.88);
        }

        .site-header.menu-is-open {
            background: rgba(var(--bg), 0.97);
        }
    }

    .site-header.is-scrolled {
        border-bottom-color: rgba(var(--text), 0.1);
    }

    .header-inner {
        height: var(--header-height);
        max-width: var(--max-width);
        margin-inline: auto;
        padding-inline: var(--content-padding);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
    }

    @media (max-width: 768px) {
        .header-inner {
            padding-inline: var(--content-padding-mobile);
        }
    }

    .brand-link {
        font-family: var(--font-title);
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.03em;
        color: var(--color-text);
        white-space: nowrap;
        flex-shrink: 0;
        transition: opacity var(--duration-fast) ease;
    }

    .brand-link:hover {
        opacity: 0.65;
    }

    .desktop-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        flex-shrink: 0;
    }

    .social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        color: var(--color-muted);
        transition: color var(--duration-fast) ease;
    }

    .social-link:hover {
        color: var(--color-text);
    }

    .menu-toggle {
        --bar-w: 16px;
        --bar-h: 1.5px;
        --bar-gap: 4.5px;
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--bar-gap);
        width: 36px;
        height: 36px;
        padding: 0;
        background: none;
        border: none;
        border-radius: var(--radius-sm);
        color: var(--color-muted);
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        transition: color var(--duration-fast) ease;
    }

    .menu-toggle:hover {
        color: var(--color-text);
    }

    .bar {
        display: block;
        width: var(--bar-w);
        height: var(--bar-h);
        background: currentColor;
        border-radius: 999px;
        transition:
            transform var(--duration-fast) var(--ease-spring),
            opacity var(--duration-fast) ease;
    }

    .menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
        transform: translateY(calc(var(--bar-gap) + var(--bar-h))) rotate(45deg);
    }

    .menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }

    .menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
        transform: translateY(calc(-1 * (var(--bar-gap) + var(--bar-h))))
            rotate(-45deg);
    }

    .mobile-menu {
        background: rgba(var(--bg), 0.97);
        border-top: 1px solid rgba(var(--text), 0.06);
    }

    @supports (backdrop-filter: blur(1px)) {
        .mobile-menu {
            background: rgba(var(--bg), 0.92);
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
        }
    }

    .mobile-menu-inner {
        overflow: hidden;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .mobile-menu-inner > :global(a),
    :global(a.mobile-link) {
        display: flex;
        align-items: center;
        padding: 0.8rem var(--content-padding-mobile);
        min-height: 44px;
        font-family: var(--font-title);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        color: var(--color-muted);
        border-bottom: 1px solid rgba(var(--text), 0.04);
        transition: color var(--duration-fast) ease;
    }

    .mobile-menu-inner > :global(a:last-child),
    :global(a.mobile-link:last-child) {
        border-bottom: none;
    }

    .mobile-menu-inner > :global(a.active),
    :global(a.mobile-link.active) {
        color: var(--color-accent);
    }

    @keyframes nav-item-in {
        from {
            opacity: 0;
            transform: translateX(-8px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .mobile-menu.is-open :global(a.mobile-link) {
        animation: nav-item-in var(--duration-fast) var(--ease-spring) both;
    }

    .mobile-menu.is-open :global(a.mobile-link:nth-child(1)) {
        animation-delay: 0.07s;
    }
    .mobile-menu.is-open :global(a.mobile-link:nth-child(2)) {
        animation-delay: 0.11s;
    }
    .mobile-menu.is-open :global(a.mobile-link:nth-child(3)) {
        animation-delay: 0.15s;
    }
    .mobile-menu.is-open :global(a.mobile-link:nth-child(4)) {
        animation-delay: 0.19s;
    }
    .mobile-menu.is-open :global(a.mobile-link:nth-child(5)) {
        animation-delay: 0.23s;
    }
    .mobile-menu.is-open :global(a.mobile-link:nth-child(6)) {
        animation-delay: 0.27s;
    }

    @media (max-width: 768px) {
        .desktop-nav {
            display: none;
        }

        .menu-toggle {
            display: flex;
        }

        .mobile-menu {
            display: grid;
            grid-template-rows: 0fr;
            opacity: 0;
            transition:
                grid-template-rows var(--duration-base) var(--ease-spring),
                opacity var(--duration-fast) ease;
        }

        .mobile-menu.is-open {
            grid-template-rows: 1fr;
            opacity: 1;
            box-shadow: var(--shadow-soft);
        }
    }

    @media (min-width: 769px) {
        .mobile-menu {
            display: none;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .site-header,
        .mobile-menu,
        .bar {
            transition: none;
        }

        .mobile-menu.is-open :global(a.mobile-link) {
            animation: none;
            opacity: 1;
        }
    }
</style>
