---
import { GITHUB_URL, SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const navLinks = [
	{ href: "/", label: "Accueil" },
	{ href: "/about", label: "À propos" },
	{ href: "/blog", label: "Blog" },
	{ href: "/tools", label: "Outils" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="site-header">
	<div class="header-inner">
		<a href="/" class="brand-link">{SITE_TITLE}</a>

		<nav class="desktop-nav" aria-label="Navigation principale">
			{
				navLinks.map(({ href, label }) => (
					<HeaderLink href={href}>{label}</HeaderLink>
				))
			}
		</nav>

		<div class="header-right">
			<a
				href={GITHUB_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="social-link"
				aria-label="Voir mon GitHub"
			>
				<svg
					viewBox="0 0 16 16"
					width="18"
					height="18"
					fill="currentColor"
					aria-hidden="true"
				>
					<path
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>

			<button
				id="menu-toggle"
				class="menu-toggle"
				aria-label="Ouvrir le menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg
					width="20"
					height="20"
					viewBox="0 0 20 20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					aria-hidden="true"
				>
					<line x1="2" y1="4" x2="18" y2="4"></line>
					<line x1="2" y1="10" x2="18" y2="10"></line>
					<line x1="2" y1="16" x2="18" y2="16"></line>
				</svg>
			</button>
		</div>
	</div>

	<nav
		id="mobile-menu"
		class="mobile-menu"
		aria-label="Navigation mobile"
		aria-hidden="true"
	>
		{
			navLinks.map(({ href, label }) => (
				<HeaderLink href={href} class="mobile-link">
					{label}
				</HeaderLink>
			))
		}
	</nav>
</header>

<script>
	(function () {
		const toggle = document.getElementById("menu-toggle");
		const menu = document.getElementById("mobile-menu");

		if (!toggle || !menu) return;

		if (toggle.hasAttribute("data-menu-initialized")) return;
		toggle.setAttribute("data-menu-initialized", "true");

		const isOpen = () => toggle.getAttribute("aria-expanded") === "true";

		const open = () => {
			toggle.setAttribute("aria-expanded", "true");
			toggle.setAttribute("aria-label", "Fermer le menu");
			menu.setAttribute("aria-hidden", "false");
			menu.classList.add("is-open");
		};

		const close = () => {
			toggle.setAttribute("aria-expanded", "false");
			toggle.setAttribute("aria-label", "Ouvrir le menu");
			menu.setAttribute("aria-hidden", "true");
			menu.classList.remove("is-open");
		};

		const handleToggleClick = (e: MouseEvent) => {
			e.stopPropagation();
			isOpen() ? close() : open();
		};

		const handleLinkClick = () => close();

		const mediaQuery = window.matchMedia("(min-width: 769px)");
		const handleMediaChange = (e: MediaQueryListEvent) => {
			if (e.matches) close();
		};

		toggle.addEventListener("click", handleToggleClick);
		menu.querySelectorAll("a").forEach((link) =>
			link.addEventListener("click", handleLinkClick),
		);
		mediaQuery.addEventListener("change", handleMediaChange);

		window.addEventListener(
			"astro:before-swap",
			() => {
				toggle.removeEventListener("click", handleToggleClick);
				menu.querySelectorAll("a").forEach((link) =>
					link.removeEventListener("click", handleLinkClick),
				);
				mediaQuery.removeEventListener("change", handleMediaChange);
				toggle.removeAttribute("data-menu-initialized");
			},
			{ once: true },
		);
	})();
</script>

<style>
	/* ========== HEADER ========== */
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
	}

	.header-inner {
		height: 60px;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	/* ========== BRAND ========== */
	.brand-link {
		font-family: var(--font-title);
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-text);
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.2s ease;
	}

	.brand-link:hover {
		color: var(--color-accent);
	}

	/* ========== DESKTOP NAV ========== */
	.desktop-nav {
		display: flex;
		align-items: center;
		gap: 1.75rem;
	}

	/* ========== HEADER RIGHT ========== */
	.header-right {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.social-link {
		display: flex;
		align-items: center;
		color: rgba(var(--text), 0.5);
		transition: color 0.2s ease;
	}

	.social-link:hover {
		color: var(--color-accent);
	}

	/* ========== BURGER ========== */
	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		background: none;
		border: 1px solid rgba(var(--accent), 0.25);
		border-radius: 4px;
		color: var(--color-accent);
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
	}

	/* ========== MOBILE MENU ========== */
	.mobile-menu {
		display: none;
		flex-direction: column;
		background: var(--color-bg);
		border-top: 1px solid rgba(var(--accent), 0.1);
	}

	.mobile-menu.is-open {
		display: flex;
	}

	.mobile-menu > :global(a),
	:global(a.mobile-link) {
		display: block;
		padding: 0.85rem 1.5rem;
		font-size: 1rem;
		border-bottom: 1px solid rgba(var(--accent), 0.06);
	}

	/* ========== RESPONSIVE ========== */
	@media (max-width: 768px) {
		.desktop-nav {
			display: none;
		}

		.menu-toggle {
			display: flex;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.brand-link,
		.social-link {
			transition: none;
		}
	}
</style>