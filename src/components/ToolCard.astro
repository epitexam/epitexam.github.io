---
export interface Props {
  icon: string;
  name: string;
  description: string;
  link?: string;
}

const { icon, name, description, link } = Astro.props;

const CardTag = link ? "a" : "div";
const cardProps = link
  ? {
      href: link,
      target: "_blank",
      rel: "noopener noreferrer",
      "aria-label": `En savoir plus sur ${name} (s'ouvre dans un nouvel onglet)`,
    }
  : {};
---

<CardTag class="tool-card" {...cardProps}>
  <div class="scanline"></div>
  <div class="card-glow"></div>
  <div class="tool-inner">
    <div class="tool-icon-container">
      <span class="tool-icon-text">{icon}</span>
    </div>
    <div class="tool-content">
      <h3 class="tool-title">
        {name}
        {
          link && (
            <span class="external-link-icon" aria-hidden="true">
              ↗
            </span>
          )
        }
      </h3>
      <p class="tool-description">{description}</p>
    </div>
  </div>
</CardTag>

<style>
  .tool-card {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 1.25rem;
    background: linear-gradient(
      145deg,
      rgba(var(--bg), 1) 0%,
      rgba(var(--accent), 0.06) 100%
    );
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      transform var(--duration-base) var(--ease-spring),
      border-color var(--duration-base) var(--ease-spring),
      box-shadow var(--duration-base) var(--ease-spring);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    color: inherit;
  }

  a.tool-card {
    cursor: pointer;
  }

  a.tool-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--accent), 0.45);
    box-shadow:
      0 12px 36px -8px rgba(var(--accent), 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(var(--accent), 0.18) 0%,
      transparent 65%
    );
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transition: opacity var(--duration-base) ease;
  }

  .tool-card:hover .card-glow {
    opacity: 1;
  }

  .scanline {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(var(--accent), 0.13) 50%,
      transparent 100%
    );
    z-index: 2;
    pointer-events: none;
    transform: translateY(-100%);
  }

  .tool-card:hover .scanline {
    animation: scan 3s linear infinite;
  }

  @keyframes scan {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(300%);
    }
  }

  .tool-inner {
    display: flex;
    align-items: flex-start;
    text-align: left;
    gap: 1.25rem;
    z-index: 3;
    position: relative;
  }

  .tool-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    min-width: 3rem;
    min-height: 3rem;
    background: rgba(var(--accent), 0.08);
    border: 1px solid rgba(var(--accent), 0.28);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition:
      border-color var(--duration-base) ease,
      box-shadow var(--duration-base) ease,
      transform var(--duration-base) ease,
      background var(--duration-base) ease;
    overflow: hidden;
  }

  .tool-icon-text {
    font-size: 1.15rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tool-card:hover .tool-icon-container {
    border-color: var(--color-accent);
    background: rgba(var(--accent), 0.15);
    box-shadow: 0 0 16px rgba(var(--accent), 0.35);
    transform: scale(1.06) rotate(-3deg);
  }

  .tool-content {
    flex: 1;
    min-width: 0;
  }

  .tool-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-title);
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color var(--duration-base) ease;
    animation: none;
  }

  .external-link-icon {
    font-size: 0.9rem;
    opacity: 0;
    transform: translateY(2px) translateX(-4px);
    transition:
      opacity var(--duration-base) var(--ease-spring),
      transform var(--duration-base) var(--ease-spring);
    color: var(--color-accent);
  }

  a.tool-card:hover .external-link-icon {
    opacity: 1;
    transform: translateY(-2px) translateX(0);
  }

  .tool-card:hover .tool-title {
    color: var(--color-accent);
  }

  .tool-description {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(var(--text), 0.6);
    word-wrap: break-word;
    white-space: normal;
    transition: color var(--duration-base) ease;
  }

  a.tool-card:hover .tool-description {
    color: rgba(var(--text), 0.8);
  }

  @media (max-width: 640px) {
    .tool-card {
      padding: 1rem;
    }
    .tool-inner {
      gap: 1rem;
    }
    .tool-icon-container {
      width: 2.5rem;
      height: 2.5rem;
      min-width: 2.5rem;
      min-height: 2.5rem;
    }
    .tool-icon-text {
      font-size: 0.9rem;
    }
    .tool-title {
      font-size: 1rem;
    }
    .tool-description {
      font-size: 0.85rem;
    }
    .external-link-icon {
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-card:hover .scanline {
      animation: none;
    }
    .tool-card:hover {
      transform: none;
    }
    .tool-card:hover .tool-icon-container {
      transform: none;
    }
  }
</style>
