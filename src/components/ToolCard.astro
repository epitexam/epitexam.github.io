---
export interface Props {
  icon: string;
  name: string;
  description: string;
  level?: "mastered" | "practiced" | "exploring";
  link?: string;
}

const { icon, name, description, level = "practiced", link } = Astro.props;

const CardTag = link ? "a" : "div";
const cardProps = link
  ? {
      href: link,
      target: "_blank",
      rel: "noopener noreferrer",
      "aria-label": `En savoir plus sur ${name} (s'ouvre dans un nouvel onglet)`,
    }
  : {};

const LEVEL_LABELS: Record<string, string> = {
  mastered: "Maîtrisé",
  practiced: "Pratiqué",
  exploring: "En exploration",
};

const levelLabel = LEVEL_LABELS[level] ?? level;
---

<CardTag class="tool-card" data-level={level} {...cardProps}>
  <div class="card-glow" aria-hidden="true"></div>
  <div class="tool-inner">
    <div class="tool-icon-container">
      <span class="tool-icon-text" aria-hidden="true">{icon}</span>
    </div>
    <div class="tool-content">
      <h3 class="tool-title">
        {name}
        {
          link && (
            <span class="external-link-icon" aria-hidden="true">
              ↗
            </span>
          )
        }
      </h3>
      <p class="tool-description">{description}</p>
    </div>
  </div>
  <span
    class="level-indicator"
    aria-label={`Niveau : ${levelLabel}`}
    role="img"
  />
</CardTag>

<style>
  .tool-card {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 1.25rem;
    background: linear-gradient(
      145deg,
      rgba(var(--bg, 9, 9, 9), 1) 0%,
      rgba(var(--accent, 255, 255, 255), 0.06) 100%
    );
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      transform var(--duration-base) var(--ease-spring),
      border-color var(--duration-base) var(--ease-spring),
      box-shadow var(--duration-base) var(--ease-spring);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    color: inherit;
  }

  .tool-card :is(h1, h2, h3, h4, h5, h6) {
    animation: none !important;
  }

  a.tool-card {
    cursor: pointer;
  }

  a.tool-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--accent, 255, 255, 255), 0.45);
    box-shadow:
      0 12px 36px -8px rgba(var(--accent, 255, 255, 255), 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(var(--accent, 255, 255, 255), 0.18) 0%,
      transparent 65%
    );
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transition: opacity var(--duration-base) ease;
  }

  .tool-card:hover .card-glow {
    opacity: 1;
  }

  .tool-inner {
    display: flex;
    align-items: flex-start;
    text-align: left;
    gap: 1.25rem;
    z-index: 3;
    position: relative;
  }

  .tool-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    min-width: 3rem;
    min-height: 3rem;
    background: rgba(var(--accent, 255, 255, 255), 0.08);
    border: 1px solid rgba(var(--accent, 255, 255, 255), 0.28);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition:
      border-color var(--duration-base) ease,
      background var(--duration-base) ease;
    overflow: hidden;
  }

  .tool-icon-text {
    font-size: 1.15rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tool-card[data-level="mastered"] .tool-icon-container {
    border-color: rgba(var(--accent, 255, 255, 255), 0.8);
    background: rgba(var(--accent, 255, 255, 255), 0.15);
  }
  .tool-card[data-level="practiced"] .tool-icon-container {
    border-color: rgba(var(--accent, 255, 255, 255), 0.4);
    background: rgba(var(--accent, 255, 255, 255), 0.08);
  }
  .tool-card[data-level="exploring"] .tool-icon-container {
    border-color: rgba(var(--accent, 255, 255, 255), 0.2);
    background: rgba(var(--accent, 255, 255, 255), 0.03);
    opacity: 0.8;
  }

  .tool-content {
    flex: 1;
    min-width: 0;
  }

  .tool-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-title);
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color var(--duration-base) ease;
  }

  .external-link-icon {
    font-size: 0.9rem;
    opacity: 0;
    transform: translateY(2px) translateX(-4px);
    transition:
      opacity var(--duration-base) var(--ease-spring),
      transform var(--duration-base) var(--ease-spring);
    color: var(--color-accent);
  }

  a.tool-card:hover .external-link-icon {
    opacity: 1;
    transform: translateY(-2px) translateX(0);
  }

  .tool-card:hover .tool-title {
    color: var(--color-accent);
  }

  .tool-description {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(var(--text, 232, 232, 234), 0.82);
    word-wrap: break-word;
    white-space: normal;
    transition: color var(--duration-base) ease;
  }

  a.tool-card:hover .tool-description {
    color: rgba(var(--text, 232, 232, 234), 0.8);
  }

  .level-indicator {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.4;
  }

  .tool-card[data-level="mastered"] .level-indicator {
    background: var(--color-accent);
    opacity: 1;
    box-shadow: 0 0 6px var(--color-accent);
  }
  .tool-card[data-level="practiced"] .level-indicator {
    background: var(--color-accent);
    opacity: 0.6;
  }
  .tool-card[data-level="exploring"] .level-indicator {
    background: rgba(var(--text, 232, 232, 234), 0.5);
    opacity: 0.3;
  }

  @media (max-width: 640px) {
    .tool-card {
      padding: 1rem;
    }
    .tool-inner {
      gap: 1rem;
    }
    .tool-icon-container {
      width: 2.5rem;
      height: 2.5rem;
      min-width: 2.5rem;
      min-height: 2.5rem;
    }
    .tool-icon-text {
      font-size: 0.9rem;
    }
    .tool-title {
      font-size: 1rem;
    }
    .tool-description {
      font-size: 0.85rem;
    }
    .external-link-icon {
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-card:hover {
      transform: none;
    }
  }
</style>