---
interface Props {
  user?: string;
  machine?: string;
  title?: string;
}

const {
  user = "guest",
  machine = "epitexam.io",
  title = "terminal",
} = Astro.props;

const terminalId = `terminal-${Math.random().toString(36).slice(2, 9)}`;
const wsApiUrl = import.meta.env.WS_API_URL ?? "wss://echo.websocket.org";
---

<div class="terminal-card" id={terminalId} data-ws-url={wsApiUrl}>
  <div class="terminal-header">
    <div class="terminal-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <div class="terminal-title">{title}</div>
    <div class="terminal-status" data-status></div>
  </div>

  <div class="terminal-body">
    <div class="terminal-output" data-output>
      <div class="terminal-line">
        <span class="terminal-muted">Bienvenue sur {machine}. Tapez </span>
        <code class="terminal-code">help</code>
        <span class="terminal-muted"> pour voir les commandes.</span>
      </div>
    </div>

    <div class="terminal-input-line">
      <span class="terminal-prompt" data-prompt>{user}@{machine}:~$</span>
      <input
        type="text"
        class="terminal-input"
        data-input
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        autofocus
      />
    </div>
  </div>
</div>

<script>
  document
    .querySelectorAll<HTMLElement>(".terminal-card")
    .forEach(initTerminal);

  function initTerminal(container: HTMLElement) {
    const output = container.querySelector<HTMLElement>("[data-output]")!;
    const input = container.querySelector<HTMLInputElement>("[data-input]")!;
    const promptEl = container.querySelector<HTMLElement>("[data-prompt]")!;
    const statusEl = container.querySelector<HTMLElement>("[data-status]")!;

    const defaultPrompt = promptEl.textContent ?? "";
    const defaultPlaceholder = "tapez 'help'...";
    const wsApiUrl = container.dataset.wsUrl ?? "";
    let socket: WebSocket | null = null;

    let currentMode: "shell" | "program" = "shell";
    let currentProgram: string | null = null;

    const history: string[] = [];
    let historyIdx = -1;
    let tempInput = "";

    input.placeholder = defaultPlaceholder;

    function setStatus(state: "idle" | "connecting" | "connected" | "error") {
      if (state === "idle") {
        statusEl.innerHTML = "";
        return;
      }
      const labels: Record<string, string> = {
        connecting: "connexion",
        connected: "connecté",
        error: "erreur",
      };
      statusEl.innerHTML = `<span class="status-dot status-${state}"></span><span>${labels[state]}</span>`;
    }

    const programs: Record<
      string,
      {
        start: () => void;
        handleInput: (cmd: string) => void;
      }
    > = {
      ws: {
        start() {
          if (!wsApiUrl) {
            printLine("Erreur : WS_API_URL n'est pas configurée.");
            return;
          }

          currentMode = "program";
          currentProgram = "ws";
          promptEl.textContent = "ws>";
          input.placeholder = "écrire un message...";
          setStatus("connecting");
          printLine(`Connexion à ${wsApiUrl}...`);

          try {
            socket = new WebSocket(wsApiUrl);
          } catch {
            printLine("Erreur : URL WebSocket invalide.");
            setStatus("idle");
            exitProgram();
            return;
          }

          socket.addEventListener("open", () => {
            setStatus("connected");
            printLine(
              "Connecté. Tapez 'exit' pour quitter, Ctrl+L pour effacer.",
            );
            input.focus();
          });

          socket.addEventListener("message", (event) => {
            const data =
              typeof event.data === "string"
                ? event.data
                : "[message binaire reçu]";
            printLine(data, false, "terminal-ws-in");
          });

          socket.addEventListener("close", () => {
            if (currentProgram === "ws") {
              printLine("Connexion fermée.");
              setStatus("idle");
              exitProgram();
            }
          });

          socket.addEventListener("error", () => {
            setStatus("error");
            printLine("Erreur de connexion WebSocket.");
          });
        },
        handleInput(cmd) {
          if (cmd === "exit" || cmd === "quit") {
            socket?.close();
            socket = null;
            setStatus("idle");
            exitProgram();
            return;
          }
          if (!cmd) return;
          if (socket && socket.readyState === WebSocket.OPEN) {
            socket.send(cmd);
          } else {
            printLine("Non connecté.");
          }
        },
      },
    };

    const shellCommands = ["help", "clear", "exit", ...Object.keys(programs)];

    function exitProgram() {
      currentMode = "shell";
      currentProgram = null;
      promptEl.textContent = defaultPrompt;
      input.placeholder = defaultPlaceholder;
    }

    function printLine(text: string, isHtml = false, extraClass = "") {
      const line = document.createElement("div");
      line.className = extraClass
        ? `terminal-line ${extraClass}`
        : "terminal-line";
      if (isHtml) line.innerHTML = text;
      else line.textContent = text;
      output.appendChild(line);
      scrollToBottom();
    }

    function scrollToBottom() {
      output.scrollTop = output.scrollHeight;
    }

    function handleShellCommand(cmd: string) {
      if (cmd === "help") {
        printLine("Commandes disponibles :");
        printLine(
          "  <span class='terminal-code'>help</span>    - Affiche cette aide",
          true,
        );
        printLine(
          "  <span class='terminal-code'>clear</span>   - Efface l'écran (Ctrl+L)",
          true,
        );
        printLine(
          "  <span class='terminal-code'>ws</span>      - Connexion WebSocket",
          true,
        );
        printLine(
          "  <span class='terminal-code'>exit</span>    - Ferme la connexion",
          true,
        );
      } else if (cmd === "clear") {
        output.innerHTML = "";
      } else if (cmd === "exit") {
        printLine("Connection closed.");
      } else if (programs[cmd]) {
        programs[cmd].start();
      } else if (cmd) {
        printLine(`bash: ${cmd}: command not found`);
      }
    }

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const cmd = input.value.trim();

        const historyLine = document.createElement("div");
        historyLine.className = "terminal-line terminal-history";
        historyLine.textContent = `${promptEl.textContent} ${cmd}`;
        output.appendChild(historyLine);

        if (
          cmd &&
          (history.length === 0 || history[history.length - 1] !== cmd)
        ) {
          history.push(cmd);
        }
        historyIdx = -1;
        tempInput = "";

        if (currentMode === "program" && currentProgram) {
          programs[currentProgram].handleInput(cmd);
        } else {
          handleShellCommand(cmd);
        }

        input.value = "";
        scrollToBottom();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (history.length > 0) {
          if (historyIdx === -1) {
            tempInput = input.value;
            historyIdx = history.length - 1;
          } else if (historyIdx > 0) {
            historyIdx--;
          }
          input.value = history[historyIdx];
        }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIdx !== -1) {
          if (historyIdx < history.length - 1) {
            historyIdx++;
            input.value = history[historyIdx];
          } else {
            historyIdx = -1;
            input.value = tempInput;
          }
        }
      } else if (e.key === "Tab" && currentMode === "shell") {
        e.preventDefault();
        const current = input.value.trim();
        if (!current) return;

        const matches = shellCommands.filter((cmd) => cmd.startsWith(current));
        if (matches.length === 1) {
          input.value = matches[0] + " ";
        } else if (matches.length > 1) {
          printLine(matches.join("  "));
        }
      } else if (e.ctrlKey) {
        if (e.key === "c" || e.key === "C") {
          e.preventDefault();
          const interruptLine = document.createElement("div");
          interruptLine.className = "terminal-line terminal-history";
          interruptLine.textContent = `${promptEl.textContent} ${input.value}^C`;
          output.appendChild(interruptLine);

          if (currentMode === "program") {
            if (currentProgram === "ws") {
              socket?.close();
              socket = null;
              setStatus("idle");
            }
            printLine("Programme interrompu.");
            exitProgram();
          }
          input.value = "";
          scrollToBottom();
        } else if (e.key === "l" || e.key === "L") {
          e.preventDefault();
          output.innerHTML = "";
          scrollToBottom();
        }
      }
    });

    container.addEventListener("click", () => input.focus());
  }
</script>

<style>
  .terminal-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-strong);
    overflow: hidden;
    font-family: var(--font-code);
    transition:
      border-color var(--duration-base) ease,
      box-shadow var(--duration-base) ease;
  }

  @media (hover: hover) {
    .terminal-card:hover {
      border-color: rgba(var(--accent), 0.2);
      box-shadow: var(--shadow-strong), var(--glow);
    }
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--tint-05);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dots {
    display: flex;
    gap: 0.4rem;
  }
  .dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--tint-20);
  }
  .dot-red {
    background: rgba(248, 113, 113, 0.7);
  }
  .dot-yellow {
    background: rgba(251, 191, 36, 0.7);
  }
  .dot-green {
    background: rgba(134, 239, 172, 0.7);
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.8rem;
    font-family: var(--font-title);
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .terminal-status {
    min-width: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--tint-20);
    flex-shrink: 0;
  }

  .status-connecting {
    background: rgba(251, 191, 36, 0.85);
    animation: status-pulse 1.2s ease-in-out infinite;
  }

  .status-connected {
    background: rgb(var(--badge-green-rgb));
  }

  .status-error {
    background: rgb(var(--color-error-rgb));
  }

  @keyframes status-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .terminal-body {
    padding: 1.25rem 1.25rem 1rem;
    min-height: 40rem;
    max-height: 55vh;
    display: flex;
    flex-direction: column;
  }

  .terminal-output {
    flex: 1;
    overflow-y: auto;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text);
    scrollbar-width: thin;
  }

  .terminal-output::-webkit-scrollbar {
    width: 6px;
  }
  .terminal-output::-webkit-scrollbar-thumb {
    background: var(--tint-20);
    border-radius: 999px;
  }

  .terminal-line {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal-line + .terminal-line {
    margin-block-start: 0.15rem;
  }
  .terminal-history {
    color: var(--color-muted);
  }
  .terminal-muted {
    color: var(--color-muted);
  }

  .terminal-ws-in {
    color: var(--color-text);
  }
  .terminal-ws-in::before {
    content: "← ";
    color: var(--color-muted);
  }

  .terminal-code {
    font-family: var(--font-code);
    font-size: 0.85em;
    padding: 0.1em 0.35em;
    background: var(--tint-10);
    border: 1px solid var(--tint-14);
    border-radius: var(--radius-sm);
    color: var(--color-text);
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: transparent;
    border: none;
    padding: 0;
    margin-top: 0.25rem;
  }

  .terminal-prompt {
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.9rem;
    white-space: nowrap;
    user-select: none;
  }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-family: var(--font-code);
    font-size: 0.9rem;
    padding: 0;
    caret-color: var(--color-accent);
  }

  .terminal-input::placeholder {
    color: var(--color-muted);
    opacity: 0.3;
  }

  @media (max-width: 480px) {
    .terminal-body {
      padding: 1rem;
      min-height: 20rem;
      max-height: 60vh;
    }
    .terminal-title {
      display: none;
    }
  }
</style>
