---
export interface Props {
    href?: string;
    label?: string;
    active?: boolean;
}

const {
    href = "/contact",
    label = "Ouvert aux opportunités",
    active = true,
} = Astro.props;

if (!active) return;
---

<a href={href} class="status-badge" aria-label={`Statut : ${label}`}>
    <span class="dot-ring" aria-hidden="true">
        <span class="status-dot"></span>
    </span>
    <span class="status-label">{label}</span>
</a>

<style>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.45rem 1.1rem 0.45rem 0.65rem;
        background: rgba(var(--badge-green-rgb), 0.15);
        backdrop-filter: blur(10px) saturate(160%);
        -webkit-backdrop-filter: blur(10px) saturate(160%);
        border: 1.5px solid rgba(var(--badge-green-rgb), 0.4);
        border-radius: 999px;

        font-family: var(--font-title);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-decoration: none;
        color: var(--badge-text-color);

        transition: all var(--duration-base) var(--ease-spring);
    }

    .status-badge:hover {
        transform: translateY(-2px);
        background: rgba(var(--badge-green-rgb), 0.25);
        border-color: rgba(var(--badge-green-rgb), 0.7);
        box-shadow: 0 4px 12px rgba(var(--badge-green-rgb), 0.2);
    }

    .status-label {
        text-transform: uppercase;
    }

    .dot-ring {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
    }

    .dot-ring::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(var(--badge-green-rgb), 0.4);
        animation: ring-pulse 2.5s ease-in-out infinite;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgb(var(--badge-green-rgb));
        box-shadow: 0 0 8px rgba(var(--badge-green-rgb), 0.8);
        z-index: 1;
    }

    @keyframes ring-pulse {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.5;
        }
        50% {
            transform: scale(1.6);
            opacity: 0;
        }
    }

    @media (max-width: 480px) {
        .status-badge {
            font-size: 0.7rem;
            padding: 0.4rem 0.9rem 0.4rem 0.55rem;
        }
    }
</style>
