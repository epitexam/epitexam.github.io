---
export interface Props {
    href?: string;
    label?: string;
    active?: boolean;
}

const {
    href = "/contact",
    label = "Ouvert aux opportunités",
    active = true,
} = Astro.props;

if (!active) return;
---

{
    href ? (
        <a href={href} class="status-badge" aria-label={label}>
            <span class="dot-ring" aria-hidden="true">
                <span class="status-dot" />
            </span>
            <span class="status-label">{label}</span>
        </a>
    ) : (
        <span class="status-badge" aria-label={label}>
            <span class="dot-ring" aria-hidden="true">
                <span class="status-dot" />
            </span>
            <span class="status-label">{label}</span>
        </span>
    )
}

<style is:global>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.45rem 1.1rem 0.45rem 0.65rem;
        background: rgba(var(--badge-green-rgb), 0.08);
        border: 1px solid rgba(var(--badge-green-rgb), 0.2);
        border-radius: 999px;
        font-family: var(--font-title);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        text-decoration: none;
        color: rgb(var(--badge-green-rgb));
        transition: all var(--duration-base) var(--ease-spring);
        box-shadow: var(--shadow-soft);
    }

    @media (hover: hover) {
        a.status-badge:hover {
            transform: translateY(-1px);
            background: rgba(var(--badge-green-rgb), 0.12);
            border-color: rgba(var(--badge-green-rgb), 0.4);
            box-shadow: var(--shadow-strong);
        }
    }

    span.status-badge { cursor: default; }

    .dot-ring {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 14px;
    }

    .dot-ring::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(var(--badge-green-rgb), 0.4);
        animation: ring-pulse 2.5s ease-in-out infinite;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgb(var(--badge-green-rgb));
        box-shadow: 0 0 8px rgba(var(--badge-green-rgb), 0.5);
        z-index: 1;
    }

    @keyframes ring-pulse {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.6); opacity: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
        .dot-ring::before { animation: none; opacity: 0.3; }
        a.status-badge:hover { transform: none; }
    }

    @media (max-width: 480px) {
        .status-badge { font-size: 0.75rem; padding: 0.4rem 0.9rem 0.4rem 0.55rem; }
    }
</style>