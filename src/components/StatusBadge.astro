---
export interface Props {
    href?: string;
    label?: string;
    active?: boolean;
}

const {
    href = "/contact",
    label = "Ouvert aux opportunités",
    active = true,
} = Astro.props;

if (!active) return;
---

{
    href ? (
        <a href={href} class="status-badge" aria-label={label}>
            <span class="dot-ring" aria-hidden="true">
                <span class="status-dot" />
            </span>
            <span class="status-label">{label}</span>
        </a>
    ) : (
        <span class="status-badge" aria-label={label}>
            <span class="dot-ring" aria-hidden="true">
                <span class="status-dot" />
            </span>
            <span class="status-label">{label}</span>
        </span>
    )
}

<style is:global>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.45rem 1.1rem 0.45rem 0.65rem;
        background: rgba(var(--badge-green-rgb, 34, 197, 94), 0.3);
        backdrop-filter: blur(8px) saturate(160%);
        -webkit-backdrop-filter: blur(8px) saturate(160%);

        border: 1px solid rgba(var(--badge-green-rgb, 34, 197, 94), 0.5);
        border-radius: 999px;

        font-family: var(--font-title);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-decoration: none;
        text-transform: uppercase;
        color: #ffffff;

        transition: all var(--duration-base) var(--ease-spring);
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
    }

    @media (prefers-color-scheme: light) {
        .status-badge {
            color: #111111;
            background: rgba(var(--badge-green-rgb, 21, 128, 61), 0.2);
            border-color: rgba(var(--badge-green-rgb, 21, 128, 61), 0.6);
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        }
    }

    @media (hover: hover) {
        a.status-badge:hover {
            transform: translateY(-2px);
            background: rgba(var(--badge-green-rgb, 34, 197, 94), 0.45);
            border-color: rgba(var(--badge-green-rgb, 34, 197, 94), 0.8);
            box-shadow: 0 4px 12px
                rgba(var(--badge-green-rgb, 34, 197, 94), 0.3);
        }

        @media (prefers-color-scheme: light) {
            a.status-badge:hover {
                background: rgba(var(--badge-green-rgb, 21, 128, 61), 0.35);
                border-color: rgba(var(--badge-green-rgb, 21, 128, 61), 0.9);
            }
        }
    }

    span.status-badge {
        cursor: default;
    }

    .dot-ring {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
    }

    .dot-ring::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(var(--badge-green-rgb, 34, 197, 94), 0.5);
        animation: ring-pulse 2.5s ease-in-out infinite;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgb(var(--badge-green-rgb, 34, 197, 94));
        box-shadow: 0 0 8px rgba(var(--badge-green-rgb, 34, 197, 94), 0.8);
        z-index: 1;
    }

    @keyframes ring-pulse {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.5;
        }
        50% {
            transform: scale(1.6);
            opacity: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .dot-ring::before {
            animation: none;
            opacity: 0.3;
        }
        a.status-badge:hover {
            transform: none;
        }
    }

    @supports not (backdrop-filter: blur(8px)) {
        .status-badge {
            background: rgba(var(--badge-green-rgb, 34, 197, 94), 0.45);
        }
        @media (prefers-color-scheme: light) {
            .status-badge {
                background: rgba(var(--badge-green-rgb, 21, 128, 61), 0.35);
            }
        }
    }

    @media (max-width: 480px) {
        .status-badge {
            font-size: 0.7rem;
            padding: 0.4rem 0.9rem 0.4rem 0.55rem;
        }
    }
</style>
