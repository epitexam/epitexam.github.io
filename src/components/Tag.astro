---
interface Props {
    tag: string;
}

const { tag } = Astro.props;
---

<span class="tag" data-tag={tag}>
    {tag}
</span>

<style>
    .tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.9rem;
        font-size: 0.75rem;
        font-family: var(--font-title);
        font-weight: 500;
        letter-spacing: 0.02em;
        color: var(--color-text);
        background: rgba(var(--accent, 255, 255, 255), 0.08);
        border: 1px solid rgba(var(--accent, 255, 255, 255), 0.2);
        border-radius: 999px;
        transition: all var(--duration-fast) var(--ease-spring);
        cursor: default;
        white-space: nowrap;
        line-height: 1.2;
    }

    .tag:hover {
        background: rgba(var(--accent, 255, 255, 255), 0.15);
        border-color: rgba(var(--accent, 255, 255, 255), 0.35);
        transform: scale(1.02);
    }

    @media (max-width: 768px) {
        .tag {
            padding: 0.25rem 0.75rem;
            font-size: 0.7rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .tag {
            transition: none;
        }
        .tag:hover {
            transform: none;
        }
    }
</style>