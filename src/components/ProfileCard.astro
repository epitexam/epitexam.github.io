---
import { Image } from "astro:assets";
import profile from "../assets/profile.webp";
import { GITHUB_URL, SITE_TITLE } from "../consts";

interface Props {
    title: string;
    tagline: string;
    content: string[];
    contactUrl?: string;
}

const { title, tagline, content, contactUrl = "/contact" } = Astro.props;

type Block = { header?: string; lines: string[] };
const blocks: Block[] = [];
let current: Block = { lines: [] };

for (const raw of content) {
    const trimmed = raw.trim();
    const isHeader = /^-\s+.+\s+-$/.test(trimmed);
    const isEmpty = trimmed === "";

    if (isHeader) {
        if (current.lines.length > 0 || current.header) {
            blocks.push(current);
        }
        const label = trimmed.replace(/^-\s+/, "").replace(/\s+-$/, "");
        current = { header: label, lines: [] };
    } else if (!isEmpty) {
        current.lines.push(trimmed);
    }
}
if (current.lines.length > 0 || current.header) {
    blocks.push(current);
}
---

<div class="profile-card">
    <div class="card-glow"></div>

    <div class="card-inner">
        <header class="card-header">
            <a
                href={GITHUB_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="avatar-link"
                aria-label={`Voir le profil GitHub de ${SITE_TITLE}`}
            >
                <div class="avatar-glow"></div>
                <Image
                    src={profile}
                    alt={SITE_TITLE}
                    width={72}
                    height={72}
                    class="avatar-img"
                    loading="eager"
                    fetchpriority="high"
                />
            </a>

            <div class="identity">
                <h1 class="card-title">{title}</h1>
                <p class="card-tagline">{tagline}</p>
            </div>
        </header>

        <div class="card-body">
            {
                blocks.map((block) => {
                    const lines = block.lines;
                    const isOdd = lines.length % 2 !== 0;

                    return (
                        <div class="content-section">
                            {block.header && (
                                <h2 class="section-header">{block.header}</h2>
                            )}
                            {lines.length > 0 && (
                                <div class="section-grid">
                                    {lines.map((line, index) => {
                                        const isLastOdd =
                                            isOdd && index === lines.length - 1;
                                        return (
                                            <div
                                                class={`grid-item ${isLastOdd ? "grid-item--full" : ""}`}
                                            >
                                                <span
                                                    class="grid-bullet"
                                                    aria-hidden="true"
                                                >
                                                    ▹
                                                </span>
                                                <p class="grid-text">{line}</p>
                                            </div>
                                        );
                                    })}
                                </div>
                            )}
                        </div>
                    );
                })
            }
        </div>

        <footer class="card-footer">
            <a
                href={GITHUB_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-link"
            >
                GitHub
                <svg
                    class="link-arrow"
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                >
                    <path
                        d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </svg>
            </a>
            <a href={contactUrl} class="footer-link footer-link--primary">
                Me contacter
                <svg
                    class="link-arrow"
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                >
                    <path
                        d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </svg>
            </a>
        </footer>
    </div>
</div>

<style>
    .profile-card {
        position: relative;
        width: 100%;
        background: linear-gradient(
            145deg,
            rgba(var(--bg), 1) 0%,
            rgba(var(--accent), 0.06) 100%
        );
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        isolation: isolate;
        box-shadow:
            var(--shadow-soft),
            inset 0 1px 0 rgba(255, 255, 255, 0.04);
        transition:
            border-color var(--duration-base) var(--ease-spring),
            box-shadow var(--duration-base) var(--ease-spring);
    }

    .profile-card:hover {
        border-color: rgba(var(--accent), 0.3);
        box-shadow:
            0 10px 32px -8px rgba(var(--accent), 0.15),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .card-glow {
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        background: radial-gradient(
            ellipse at 0% 0%,
            rgba(var(--accent), 0.1) 0%,
            transparent 60%
        );
        opacity: 0;
        z-index: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) ease;
    }

    .profile-card:hover .card-glow {
        opacity: 1;
    }

    .card-inner {
        position: relative;
        z-index: 1;
        padding: 1.75rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .avatar-link {
        position: relative;
        display: block;
        flex-shrink: 0;
        border-radius: 50%;
        transition: transform var(--duration-base) var(--ease-spring);
    }

    .avatar-link:hover {
        transform: scale(1.05);
    }

    .avatar-link:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 4px;
    }

    .avatar-glow {
        position: absolute;
        inset: -5px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(var(--accent), 0.2) 0%,
            transparent 70%
        );
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) ease;
        z-index: 0;
    }

    .avatar-link:hover .avatar-glow {
        opacity: 1;
    }

    .avatar-img {
        display: block;
        position: relative;
        z-index: 1;
        border-radius: 50%;
        border: 2px solid rgba(var(--accent), 0.2);
        box-shadow: var(--shadow-strong);
        transition:
            border-color var(--duration-base) ease,
            box-shadow var(--duration-base) ease;
        width: 72px;
        height: 72px;
        object-fit: cover;
    }

    .avatar-link:hover .avatar-img {
        border-color: rgba(var(--accent), 0.55);
    }

    .identity {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        min-width: 0;
    }

    .card-title {
        font-size: clamp(1.2rem, 3.5vw, 1.6rem);
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
        padding: 0;
        letter-spacing: -0.03em;
        line-height: 1.15;
        transition: color var(--duration-fast) ease;
    }

    .profile-card:hover .card-title {
        color: var(--color-accent);
    }

    .card-tagline {
        font-family: var(--font-code);
        font-size: 0.75rem;
        color: var(--color-muted);
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        padding-block: 1.5rem;
        transition: border-color var(--duration-base) ease;
    }

    .profile-card:hover .card-body {
        border-color: rgba(var(--accent), 0.15);
    }

    .content-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .section-header {
        font-family: var(--font-code);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-accent);
        margin: 0;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid rgba(var(--accent), 0.2);
    }

    .section-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    @media (min-width: 640px) {
        .section-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .grid-item {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        padding: 0.9rem 1rem;
        background: rgba(var(--text), 0.02);
        border: 1px solid rgba(var(--accent), 0.08);
        border-radius: var(--radius-sm);
        transition:
            background var(--duration-fast) ease,
            border-color var(--duration-fast) ease,
            transform var(--duration-fast) var(--ease-spring);
        grid-column: span 1;
    }

    .grid-item--full {
        grid-column: 1 / -1;
    }

    .grid-item:hover {
        background: rgba(var(--accent), 0.04);
        border-color: rgba(var(--accent), 0.25);
        transform: translateY(-2px);
    }

    .grid-bullet {
        color: var(--color-accent);
        font-size: 1.1rem;
        line-height: 1.4;
        flex-shrink: 0;
        opacity: 0.8;
    }

    .grid-text {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--color-muted);
        transition: color var(--duration-fast) ease;
    }

    .grid-item:hover .grid-text {
        color: rgba(var(--text), 0.9);
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .footer-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-family: var(--font-title);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--color-muted);
        text-decoration: none;
        position: relative;
        padding-bottom: 2px;
        transition: color var(--duration-fast) ease;
    }

    .footer-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background: currentColor;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--duration-base) var(--ease-spring);
    }

    .footer-link:hover {
        color: var(--color-accent);
    }

    .footer-link:hover::after {
        transform: scaleX(1);
    }

    .footer-link--primary {
        color: var(--color-accent);
    }

    .link-arrow {
        transition: transform var(--duration-base) var(--ease-spring);
        flex-shrink: 0;
    }

    .footer-link:hover .link-arrow {
        transform: translateX(4px);
    }

    @media (max-width: 480px) {
        .card-inner {
            padding: 1.25rem;
        }

        .avatar-img {
            width: 58px;
            height: 58px;
        }

        .card-tagline {
            white-space: normal;
            font-size: 0.7rem;
        }

        .grid-item {
            padding: 0.75rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .avatar-link:hover {
            transform: none;
        }
        .profile-card:hover .card-glow {
            opacity: 0;
        }
        .grid-item:hover {
            transform: none;
        }
        .footer-link:hover .link-arrow {
            transform: none;
        }
    }
</style>
