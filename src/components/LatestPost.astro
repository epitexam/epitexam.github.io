---
import { Image } from "astro:assets";

export interface Props {
    post: {
        id: string;
        data: {
            title: string;
            description: string;
            pubDate: Date;
            updatedDate?: Date;
            heroImage?: any;
            heroImageDescription?: string;
        };
    };
}
const { post } = Astro.props;
---

<article class="latest-post-container">
    <a
        href={`/blog/${post.id}/`}
        class="post-card"
        aria-label={`Lire l'article : ${post.data.title}`}
    >
        <div class="card-glow"></div>

        {
            post.data.heroImage && (
                <div class="post-image-container">
                    <Image
                        src={post.data.heroImage}
                        alt={post.data.heroImageDescription || post.data.title}
                        width={800}
                        height={400}
                        widths={[400, 640, 800]}
                        sizes="(max-width: 480px) 100vw, (max-width: 768px) calc(100vw - 2rem), 800px"
                        class="post-image"
                        loading="lazy"
                    />
                    <div class="image-overlay" />
                </div>
            )
        }

        <div class="post-content">
            <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                    {
                        post.data.pubDate.toLocaleDateString("fr-FR", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
                {
                    post.data.updatedDate && (
                        <span class="post-updated">
                            · Mis à jour le{" "}
                            {post.data.updatedDate.toLocaleDateString("fr-FR", {
                                year: "numeric",
                                month: "short",
                                day: "numeric",
                            })}
                        </span>
                    )
                }
            </div>

            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-description">{post.data.description}</p>

            <span class="read-more">
                Lire l'article
                <svg
                    class="arrow-icon"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                >
                    <path
                        d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </svg>
            </span>
        </div>
    </a>
</article>

<style>
    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 0 4px rgba(var(--accent), 0.5);
        }
        50% {
            box-shadow: 0 0 10px rgba(var(--accent), 1);
        }
    }

    .post-card {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        background: linear-gradient(
            145deg,
            rgba(var(--bg), 1) 0%,
            rgba(var(--accent), 0.05) 100%
        );
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        isolation: isolate;
        color: inherit;
        box-shadow:
            var(--shadow-soft),
            inset 0 1px 0 rgba(255, 255, 255, 0.04);
        transition:
            transform var(--duration-base) var(--ease-spring),
            border-color var(--duration-base) var(--ease-spring),
            box-shadow var(--duration-base) var(--ease-spring);
    }

    .post-card:hover {
        transform: translateY(-4px);
        border-color: rgba(var(--accent), 0.4);
        box-shadow:
            0 14px 40px -8px rgba(var(--accent), 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }

    .card-glow {
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        background: radial-gradient(
            ellipse at 50% 0%,
            rgba(var(--accent), 0.14) 0%,
            transparent 65%
        );
        opacity: 0;
        z-index: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) ease;
    }

    .post-card:hover .card-glow {
        opacity: 1;
    }

    .post-image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        z-index: 1;
    }

    .post-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition:
            transform var(--duration-slow) var(--ease-spring),
            filter var(--duration-slow) ease;
        filter: brightness(0.88) contrast(1.08) saturate(0.95);
    }

    .post-card:hover .post-image {
        transform: scale(1.04);
        filter: brightness(1) contrast(1.1) saturate(1.05);
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            transparent 50%,
            rgba(var(--bg), 0.55) 100%
        );
        pointer-events: none;
    }

    .post-content {
        position: relative;
        z-index: 2;
        padding: 2rem 2.5rem 2.5rem;
        display: flex;
        flex-direction: column;
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        font-family: var(--font-title);
        font-size: 0.8rem;
        color: var(--color-muted);
        margin-bottom: 0.9rem;
    }

    .post-updated {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .post-title {
        font-family: var(--font-title);
        font-size: clamp(1.4rem, 3.5vw, 1.9rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.025em;
        color: var(--color-text);
        margin: 0 0 1rem;
        transition: color var(--duration-base) ease;
        animation: none;
    }

    .post-card:hover .post-title {
        color: var(--color-accent);
    }

    .post-description {
        font-size: 0.975rem;
        line-height: 1.7;
        color: var(--color-muted);
        margin: 0 0 1.75rem;
        transition: color var(--duration-base) ease;
    }

    .post-card:hover .post-description {
        color: rgba(var(--text), 0.82);
    }

    .read-more {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--color-accent);
        font-family: var(--font-title);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        width: fit-content;
        position: relative;
        padding-bottom: 2px;
    }

    .read-more::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background: var(--color-accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--duration-base) var(--ease-spring);
    }

    .post-card:hover .read-more::after {
        transform: scaleX(1);
    }

    .arrow-icon {
        transition: transform var(--duration-base) var(--ease-spring);
        flex-shrink: 0;
    }

    .post-card:hover .arrow-icon {
        transform: translateX(5px);
    }

    @media (max-width: 768px) {
        .post-content {
            padding: 1.5rem 1.75rem 2rem;
        }
        .post-title {
            font-size: 1.35rem;
        }
        .post-description {
            font-size: 0.925rem;
        }
    }

    @media (max-width: 480px) {
        .post-content {
            padding: 1.25rem 1.5rem 1.75rem;
        }
        .post-title {
            font-size: 1.2rem;
        }
        .post-meta {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.2rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .post-card:hover {
            transform: none;
        }
        .post-card:hover .post-image {
            transform: none;
        }
        .post-card:hover .arrow-icon {
            transform: none;
        }
    }
</style>
