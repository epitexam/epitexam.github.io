---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
    SITE_TITLE,
    EDUCATION,
    EXPERIENCES,
    ABOUT_META_DESCRIPTION,
    GITHUB_URL,
} from "../consts";
import Tag from "../components/Tag.astro";

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Epitexam",
    url: "https://epitexam.github.io",
    sameAs: [GITHUB_URL],
    jobTitle: "Développeur Fullstack",
    description: ABOUT_META_DESCRIPTION,
    knowsAbout: [
        "TypeScript",
        "JavaScript",
        "React",
        "Node.js",
        "PostgreSQL",
        "Docker",
        "NestJS",
        "Next.js",
        "Go",
    ],
};
---

<!doctype html>
<html lang="fr">
    <head>
        <BaseHead
            title={`À propos - ${SITE_TITLE}`}
            description={ABOUT_META_DESCRIPTION}
        />
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>

    <body>
        <Header />

        <main class="about-main">
            <section class="content-section" aria-labelledby="about-heading">
                <SectionHeader label="À propos" level="h1" id="about-heading" />

                <div class="interests-content">
                    <p>
                        Développeur Fullstack avec <strong
                            >3 ans d'expérience</strong
                        >
                        acquise en startup SaaS et EdTech, je conçois des applications
                        robustes en m'appuyant sur <strong>TypeScript</strong>,
                        <strong>Node.js</strong> et des architectures pensées pour
                        durer.
                    </p>
                    <p>
                        J'accorde autant d'importance à la <strong
                            >lisibilité du code</strong
                        >
                        qu'à ses performances. Chaque décision technique doit pouvoir
                        s'expliquer et s'assumer dans le temps.
                    </p>
                    <p>
                        Curieux par nature, je continue d'explorer en dehors de
                        mon stack principal : <strong>Go</strong>, systèmes
                        embarqués, bas niveau. Apprendre reste une habitude
                        autant qu'une nécessité.
                    </p>
                </div>
            </section>

            <section class="content-section" aria-labelledby="parcours-heading">
                <SectionHeader
                    label="Parcours"
                    level="h2"
                    id="parcours-heading"
                />

                <div class="journey-block">
                    <h3 class="journey-label">Formation</h3>
                    <div class="journey-list">
                        {
                            EDUCATION.map((item) => (
                                <div class="journey-item">
                                    <div class="journey-header">
                                        <time class="journey-period">
                                            {item.period}
                                        </time>
                                        <p class="journey-title">
                                            {item.title}
                                        </p>
                                    </div>
                                    {item.subtitle && (
                                        <p class="journey-subtitle-text">
                                            {item.subtitle}
                                        </p>
                                    )}
                                    <p class="journey-desc">
                                        {item.description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="journey-block">
                    <h3 class="journey-label">Expériences professionnelles</h3>
                    <div class="journey-list">
                        {
                            EXPERIENCES.map((item) => (
                                <div class="journey-item">
                                    <div class="journey-header">
                                        <time class="journey-period">
                                            {item.period}
                                        </time>
                                        <p class="journey-title">
                                            {item.title}
                                        </p>
                                    </div>

                                    {item.context && (
                                        <p class="journey-context">
                                            {item.context}
                                        </p>
                                    )}

                                    <p class="journey-desc">
                                        {item.description}
                                    </p>

                                    <div class="journey-tags">
                                        {item.tags.map((tag) => (
                                            <Tag tag={tag} />
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <section
                class="content-section"
                aria-labelledby="recherche-heading"
            >
                <SectionHeader
                    label="Ce que je recherche"
                    level="h2"
                    id="recherche-heading"
                />

                <div class="interests-content">
                    <p>
                        Je cherche un poste où les décisions techniques ont du
                        <strong>poids</strong> et où le code qu'on écrit a un
                        <strong>impact réel</strong> sur le produit.
                    </p>
                    <p>
                        J'ai besoin d'une équipe exigeante, avec qui on peut
                        débattre d'<strong>architecture</strong> sans que ça soit
                        perçu comme une perte de temps.
                    </p>
                    <p>
                        Côté organisation, un rythme <strong>hybride</strong> me convient
                        parfaitement. Suffisamment de remote pour être efficace, suffisamment
                        de présentiel pour rester connecté à l'équipe.
                    </p>
                </div>
            </section>

            <section
                class="content-section"
                aria-labelledby="interests-heading"
            >
                <SectionHeader
                    label="Centres d'intérêt"
                    level="h2"
                    id="interests-heading"
                />

                <div class="interests-content">
                    <p>
                        Passionné de <strong>jeux vidéo</strong> et de <strong
                            >game design</strong
                        >, j'aime observer les mécaniques de gameplay pour voir
                        ce qui rend une expérience agréable. Ça influence
                        directement ma façon de concevoir des interfaces simples
                        et intuitives.
                    </p>
                    <p>
                        L'<strong>émulation</strong> et la <strong
                            >rétro-informatique</strong
                        > (Atari 2600, 6502) alimentent ma curiosité pour les contraintes
                        hardware et l'optimisation bas niveau. Observer comment les
                        anciens programmeurs faisaient tenir un jeu dans seulement
                        4 Ko reste un bon exercice pour comprendre l'efficacité et
                        la rigueur dans le code.
                    </p>
                    <p>
                        Grand utilisateur de l'<strong>open source</strong>,
                        j'explore les projets existants et m'inspire des
                        meilleures pratiques. Je documente parfois mes
                        découvertes et projets sur GitHub pour garder une trace
                        de mon apprentissage.
                    </p>
                </div>
            </section>

            <aside class="contact-section" aria-labelledby="contact-heading">
                <SectionHeader
                    label="Contact"
                    href="/contact"
                    linkText="Me contacter"
                    level="h2"
                    id="contact-heading"
                />

                <div class="contact-card">
                    <p>Vous recrutez ? Intéressé par une collaboration ?</p>
                    <a href="/contact" class="btn-pill btn-solid"
                        >Envoyer un message</a
                    >
                </div>
            </aside>
        </main>

        <Footer />
    </body>
</html>

<style>
    .about-main {
        max-width: 800px;
        gap: 5rem;
        display: flex;
        flex-direction: column;
        margin: 0 auto;
    }

    .content-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        width: 100%;
    }

    .journey-block {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .journey-label {
        font-family: var(--font-code);
        font-size: 1rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        opacity: 0.9;
        margin: 0;
    }

    .journey-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .journey-item {
        padding: 0.75rem 0 0.75rem 1.5rem;
        border-left: 2px solid var(--color-border);
        transition:
            border-color var(--duration-base) ease,
            padding-left var(--duration-base) var(--ease-spring);
    }

    .journey-item:hover {
        border-left-color: var(--color-accent);
        padding-left: 1.85rem;
    }

    .journey-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 0.25rem;
    }

    .journey-period {
        font-family: var(--font-code);
        font-size: 0.75rem;
        color: var(--color-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .journey-title {
        font-family: var(--font-title);
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
        letter-spacing: -0.01em;
    }

    .journey-context {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-accent);
        margin: 0.2rem 0 0.3rem;
        opacity: 0.9;
    }

    .journey-subtitle-text {
        font-size: 0.875rem;
        color: var(--color-muted);
        font-style: italic;
        margin: 0 0 0.3rem;
    }

    .journey-desc {
        font-size: 0.9rem;
        line-height: 1.7;
        color: rgba(var(--text), 0.75);
        margin: 0;
    }

    .journey-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.75rem;
    }

    .interests-content {
        font-size: 1rem;
        line-height: 1.8;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .interests-content p {
        margin: 0;
        color: rgba(var(--text), 0.8);
    }

    .contact-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .contact-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 2.5rem 2rem;
        background: rgba(var(--accent), 0.02);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        text-align: center;
    }

    .contact-card p {
        font-size: 1.1rem;
        color: var(--color-text);
        margin: 0;
    }

    .contact-card .btn-pill {
        min-width: 200px;
        justify-content: center;
    }

    .btn-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--font-title);
        font-weight: 600;
        font-size: 0.84rem;
        letter-spacing: 0.02em;
        padding: 0.7rem 1.6rem;
        border-radius: 999px;
        text-decoration: none;
        transition:
            transform var(--duration-base) var(--ease-spring),
            box-shadow var(--duration-base) ease,
            filter var(--duration-fast) ease,
            border-color var(--duration-fast) ease,
            background var(--duration-fast) ease;
    }

    .btn-solid {
        background: var(--color-accent);
        color: var(--color-bg);
        border: 1px solid transparent;
        box-shadow: 0 2px 12px rgba(var(--accent), 0.25);
    }

    .btn-solid:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(var(--accent), 0.35);
        filter: brightness(1.06);
    }

    @media (max-width: 768px) {
        .about-main {
            gap: 3.5rem;
        }

        .journey-header {
            flex-direction: column;
            gap: 0.2rem;
        }

        .journey-item:hover {
            padding-left: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .about-main {
            gap: 2.5rem;
        }

        .journey-item {
            padding-left: 1.1rem;
        }
        .journey-title {
            font-size: 0.95rem;
        }

        .interests-content {
            font-size: 0.925rem;
        }

        .contact-card {
            padding: 1.5rem;
        }

        .contact-card .btn-pill {
            min-width: 100%;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .journey-item {
            transition: none;
        }
        .journey-item:hover {
            padding-left: 1.5rem;
        }
        .btn-pill:hover {
            transform: none;
        }
    }
</style>
