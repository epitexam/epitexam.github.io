---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	ABOUT_ME,
	EDUCATION,
	EXPERIENCES,
} from "../consts";
import Avatar from "../components/Avatar.astro";
import TerminalCard from "../components/TerminalCard.astro";
import Tag from "../components/Tag.astro";
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos - ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
		/>
	</head>

	<body>
		<Header />

		<main class="about-main">
			<section class="hero-section">
				<Avatar />
				<div class="terminal-wrapper">
					<TerminalCard
						filename="presentation.md"
						content={ABOUT_ME}
					/>
				</div>
			</section>

			<section class="content-section" aria-labelledby="parcours-heading">
				<h2 id="parcours-heading" class="section-title">Parcours</h2>

				<div class="journey-block">
					<p class="journey-subtitle">Formation</p>
					<div class="journey-list">
						{
							EDUCATION.map((item) => (
								<div class="journey-item">
									<div class="journey-header">
										<span class="journey-period">
											{item.period}
										</span>
										<h3 class="journey-title">
											{item.title}
										</h3>
									</div>
									{item.subtitle && (
										<p class="journey-subtitle-text">
											{item.subtitle}
										</p>
									)}
									<p class="journey-desc">
										{item.description}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div class="journey-block">
					<p class="journey-subtitle">Expériences</p>
					<div class="journey-list">
						{
							EXPERIENCES.map((item) => (
								<div class="journey-item">
									<div class="journey-header">
										<span class="journey-period">
											{item.period}
										</span>
										<h3 class="journey-title">
											{item.title}
										</h3>
									</div>
									<p class="journey-desc">
										{item.description}
									</p>
									<div class="journey-tags">
										{item.tags.map((tag) => (
											<Tag tag={tag} />
										))}
									</div>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section
				class="content-section"
				aria-labelledby="interests-heading"
			>
				<h2 id="interests-heading" class="section-title">
					Au-delà du code
				</h2>
				<div class="interests-content">
					<p>
						Passionné de <strong>jeux vidéo</strong> et de <strong
							>game design</strong
						>, j'aime analyser les mécaniques et comprendre comment
						créer des expériences engageantes. Cet intérêt influence
						ma manière de concevoir des interfaces utilisateur.
					</p>
					<p>
						Je m'intéresse également à <strong>l'émulation</strong> et
						à la
						<strong>rétro informatique (Atari 2600)</strong>,
						comprendre comment fonctionnaient les anciennes machines
						m'aide à mieux appréhender les contraintes hardware et
						l'optimisation bas niveau.
					</p>
					<p>
						Grand utilisateur de projets <strong>open source</strong
						>, j'en mesure toute l'importance pour l'écosystème
						tech. Même si je n'ai pas encore eu l'occasion de voir
						une PR mergée, je contribue à ma manière en partageant
						mes découvertes techniques sur ce blog.
					</p>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	.about-main {
		max-width: 800px;
		gap: 5rem;
	}

	.hero-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2.5rem;
		width: 100%;
	}

	.terminal-wrapper {
		width: 100%;
		min-width: 0;
		overflow: hidden;
	}

	.content-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		width: 100%;
	}

	.section-title {
		font-size: clamp(1.4rem, 4vw, 1.9rem);
		font-weight: 700;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-border);
		margin: 0;

		animation: none;
	}

	.journey-block {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.journey-subtitle {
		font-family: var(--font-code);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-accent);
		opacity: 0.65;
		margin: 0;
	}

	.journey-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.journey-item {
		padding: 0.75rem 0 0.75rem 1.5rem;
		border-left: 2px solid var(--color-border);
		transition:
			border-color var(--duration-base) ease,
			padding-left var(--duration-base) var(--ease-spring);
	}

	.journey-item:hover {
		border-left-color: var(--color-accent);
		padding-left: 1.85rem;
	}

	.journey-header {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 0.4rem;
	}

	.journey-period {
		font-family: var(--font-code);
		font-size: 0.75rem;
		color: var(--color-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	.journey-title {
		font-family: var(--font-title);
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
		margin: 0;
		letter-spacing: -0.01em;
		animation: none;
	}

	.journey-subtitle-text {
		font-size: 0.875rem;
		color: var(--color-muted);
		font-style: italic;
		margin: 0 0 0.4rem;
	}

	.journey-desc {
		font-size: 0.9rem;
		line-height: 1.7;
		color: rgba(var(--text), 0.75);
		margin: 0;
	}

	.journey-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.75rem;
	}

	.interests-content {
		font-size: 1rem;
		line-height: 1.8;
		color: rgba(var(--text), 0.8);
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}

	.interests-content p {
		margin: 0;
		color: rgba(var(--text), 0.8);
	}

	@media (max-width: 768px) {
		.about-main {
			gap: 3.5rem;
		}

		.journey-header {
			flex-direction: column;
			gap: 0.2rem;
		}

		.journey-item:hover {
			padding-left: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.about-main {
			gap: 2.5rem;
		}

		.hero-section {
			gap: 1.75rem;
		}

		.section-title {
			font-size: 1.3rem;
		}

		.journey-item {
			padding-left: 1.1rem;
		}

		.journey-title {
			font-size: 0.95rem;
		}

		.interests-content {
			font-size: 0.925rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.journey-item:hover {
			padding-left: 1.5rem;
		}
		.journey-item {
			transition: none;
		}
	}
</style>
