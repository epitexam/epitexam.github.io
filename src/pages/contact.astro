---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

const success = Astro.url.searchParams.get("success") === "true";
---

<!doctype html>
<html lang="fr">
    <head>
        <BaseHead
            title={`Contact - ${SITE_TITLE}`}
            description="Contactez-moi pour discuter de vos projets, collaborations ou questions."
        />
    </head>

    <body>
        <Header />

        <main class="contact-main">
            <div class="contact-wrapper">
                <header class="contact-header">
                    <p class="contact-label">- Contact -</p>
                    <h1 class="contact-title">Travaillons ensemble.</h1>
                    <p class="contact-intro">
                        Un projet, une question, ou juste envie d'échanger : je
                        réponds à tous les messages sous 48h.
                    </p>
                    <div class="availability">
                        <span class="availability-dot"></span>
                        <span class="availability-text"
                            >Disponible pour de nouveaux projets</span
                        >
                    </div>
                </header>

                {
                    success && (
                        <div
                            class="notification success-notification"
                            role="status"
                            aria-live="polite"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                aria-hidden="true"
                            >
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Message envoyé : je vous réponds dès que possible.
                        </div>
                    )
                }

                <div
                    id="errorNotification"
                    class="notification error-notification hidden"
                    role="alert"
                    aria-live="assertive"
                >
                </div>

                <form
                    id="contactForm"
                    action="https://formspree.io/f/xovgkrbn"
                    method="POST"
                    class="contact-form"
                    autocomplete="on"
                    novalidate
                >
                    <input
                        type="hidden"
                        name="_next"
                        value={`${Astro.url.origin}${Astro.url.pathname}?success=true`}
                    />
                    <input
                        type="hidden"
                        name="_subject"
                        value={`Nouveau message - ${SITE_TITLE}`}
                    />

                    <div class="honeypot" aria-hidden="true">
                        <input
                            type="text"
                            name="website"
                            tabindex="-1"
                            autocomplete="off"
                        />
                    </div>

                    <div class="field-group">
                        <label for="email" class="field-label">
                            <span class="label-prefix">01.</span> Votre email
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="nom@domaine.com"
                            class="input-field"
                            autocomplete="email"
                        />
                        <p class="field-hint">Ne sera jamais partagé.</p>
                    </div>

                    <div class="field-group">
                        <label for="message" class="field-label">
                            <span class="label-prefix">02.</span> Votre message
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            required
                            rows="6"
                            placeholder="Décrivez votre projet, votre question…"
                            class="input-field textarea-field"
                            minlength="20"
                            maxlength="2000"
                            spellcheck="true"></textarea>
                        <div class="textarea-meta">
                            <span class="field-hint">Markdown supporté.</span>
                            <span class="char-counter">
                                <span id="charCount">0</span><span
                                    class="char-max">/2000</span
                                >
                            </span>
                        </div>
                    </div>

                    <div class="consent-row">
                        <input
                            type="checkbox"
                            id="privacy"
                            name="privacy"
                            required
                            class="consent-checkbox"
                        />
                        <label for="privacy" class="consent-label">
                            J'accepte que mes données soient utilisées
                            uniquement pour répondre à mon message.
                        </label>
                    </div>

                    <button id="submitBtn" type="submit" class="submit-btn">
                        <span id="submitLabel">Envoyer</span>
                        <svg
                            id="submitArrow"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                        <svg
                            id="submitSpinner"
                            class="spinner hidden"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            aria-hidden="true"
                        >
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
                        </svg>
                    </button>

                    <p class="powered-by">Propulsé par Formspree</p>
                </form>
            </div>
        </main>

        <Footer />
    </body>
</html>

<style>
    /* ── Layout ──────────────────────────────────────────── */
    .contact-main {
        width: 100%;
        max-width: var(--max-width);
        margin-inline: auto;
        padding: calc(var(--header-height) + 4rem) 1.5rem 5rem;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .contact-wrapper {
        width: 100%;
        max-width: 48rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    /* ── Header ──────────────────────────────────────────── */
    .contact-header {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 0.25rem;
    }

    .contact-label {
        font-family: var(--font-code);
        font-size: 0.8rem;
        color: var(--color-accent);
        opacity: 0.7;
        margin: 0;
        letter-spacing: 0.04em;
    }

    .contact-title {
        font-family: var(--font-title);
        font-size: clamp(1.75rem, 5vw, 2.5rem);
        font-weight: 700;
        color: var(--color-text);
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin: 0;
    }

    .contact-intro {
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--color-muted);
        margin: 0;
    }

    /* ── Availability ────────────────────────────────────── */
    .availability {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0.9rem;
        background: rgba(var(--accent), 0.06);
        border: 1px solid rgba(var(--accent), 0.18);
        border-radius: 999px;
        width: fit-content;
    }

    :global(html.light) .availability {
        background: rgba(var(--accent), 0.08);
        border-color: rgba(var(--accent), 0.3);
    }

    .availability-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--color-accent);
        flex-shrink: 0;
        animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 0 4px rgba(var(--accent), 0.5);
        }
        50% {
            box-shadow: 0 0 10px rgba(var(--accent), 1);
        }
    }

    .availability-text {
        font-family: var(--font-title);
        font-size: 0.7rem;
        color: var(--color-accent);
        letter-spacing: 0.02em;
    }

    /* ── Notifications ───────────────────────────────────── */
    .notification {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.9rem 1.1rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 500;
        animation: slideDown 0.4s cubic-bezier(0.23, 1, 0.32, 1) both;
    }

    .success-notification {
        background: rgba(var(--accent), 0.08);
        border: 1px solid rgba(var(--accent), 0.28);
        color: var(--color-accent);
    }

    .error-notification {
        background: rgba(255, 80, 80, 0.08);
        border: 1px solid rgba(255, 80, 80, 0.28);
        color: rgb(255, 110, 110);
    }

    :global(html.light) .error-notification {
        color: rgb(200, 40, 40);
    }

    .notification.hidden {
        display: none !important;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Form shell ──────────────────────────────────────── */
    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
        background: linear-gradient(
            145deg,
            rgba(var(--bg), 1) 0%,
            rgba(var(--accent), 0.04) 100%
        );
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 2rem;
        box-shadow:
            var(--shadow-soft),
            inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    :global(html.light) .contact-form {
        background: linear-gradient(
            145deg,
            rgb(var(--bg)) 0%,
            rgba(var(--accent), 0.05) 100%
        );
        border-color: rgba(var(--accent), 0.22);
        box-shadow:
            0 2px 12px rgba(var(--text), 0.07),
            0 1px 3px rgba(var(--text), 0.05),
            inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    /* ── Fields ──────────────────────────────────────────── */
    .honeypot {
        display: none;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-title);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-text);
    }

    .label-prefix {
        color: var(--color-accent);
        opacity: 0.65;
    }

    .input-field {
        width: 100%;
        box-sizing: border-box;
        background: rgba(var(--accent), 0.03);
        border: 1px solid rgba(var(--accent), 0.15);
        border-radius: var(--radius-sm);
        padding: 0.8rem 1rem;
        color: var(--color-text);
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.5;
        transition:
            border-color 0.25s ease,
            background 0.25s ease,
            box-shadow 0.25s ease;
    }

    :global(html.light) .input-field {
        background: rgba(var(--accent), 0.04);
        border-color: rgba(var(--accent), 0.25);
        color: rgb(var(--text));
    }

    .input-field::placeholder {
        color: rgba(var(--text), 0.22);
    }
    :global(html.light) .input-field::placeholder {
        color: rgba(var(--text), 0.35);
    }

    .input-field:focus {
        outline: none;
        border-color: rgba(var(--accent), 0.55);
        background: rgba(var(--accent), 0.05);
        box-shadow: 0 0 0 3px rgba(var(--accent), 0.1);
    }

    :global(html.light) .input-field:focus {
        border-color: rgba(var(--accent), 0.65);
        box-shadow: 0 0 0 3px rgba(var(--accent), 0.12);
    }

    .textarea-field {
        resize: none;
        min-height: 140px;
    }

    .field-hint {
        font-size: 0.72rem;
        color: var(--color-muted);
        margin: 0;
    }

    .textarea-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .char-counter {
        font-family: var(--font-title);
        font-size: 0.7rem;
        color: var(--color-muted);
        transition: color 0.2s ease;
    }

    .char-max {
        opacity: 0.5;
    }

    .char-counter.near-limit {
        color: rgb(255, 160, 60);
    }
    .char-counter.at-limit {
        color: rgb(255, 80, 80);
    }

    /* ── Consent ─────────────────────────────────────────── */
    .consent-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.85rem 1rem;
        background: rgba(var(--accent), 0.03);
        border: 1px solid rgba(var(--accent), 0.1);
        border-radius: var(--radius-sm);
    }

    :global(html.light) .consent-row {
        background: rgba(var(--accent), 0.05);
        border-color: rgba(var(--accent), 0.18);
    }

    .consent-checkbox {
        margin-top: 0.1rem;
        accent-color: var(--color-accent);
        flex-shrink: 0;
        cursor: pointer;
        width: 15px;
        height: 15px;
    }

    .consent-label {
        font-size: 0.78rem;
        color: var(--color-muted);
        cursor: pointer;
        line-height: 1.6;
    }

    /* ── Submit ──────────────────────────────────────────── */
    .submit-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        padding: 0.9rem 1.5rem;
        background: var(--color-accent);
        color: var(--color-bg);
        border: none;
        border-radius: var(--radius-sm);
        font-family: var(--font-title);
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition:
            transform 0.3s cubic-bezier(0.23, 1, 0.32, 1),
            box-shadow 0.3s ease,
            filter 0.3s ease;
    }

    .submit-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(var(--accent), 0.35);
        filter: brightness(1.06);
    }

    .submit-btn:active:not(:disabled) {
        transform: translateY(0);
    }

    .submit-btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .spinner {
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .hidden {
        display: none !important;
    }

    .powered-by {
        font-size: 0.62rem;
        text-align: center;
        color: rgba(var(--text), 0.2);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: -0.5rem 0 0;
    }

    /* ── Responsive ──────────────────────────────────────── */
    @media (max-width: 768px) {
        .contact-main {
            padding-top: calc(var(--header-height) + 2.5rem);
            align-items: flex-start;
        }

        .contact-form {
            padding: 1.25rem;
        }
    }

    /* ── Reduced motion ──────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
        .availability-dot,
        .spinner {
            animation: none;
        }
        .notification {
            animation: none;
        }
        .submit-btn:hover:not(:disabled) {
            transform: none;
        }
    }
</style>

<script>
    (function () {
        const form = document.getElementById(
            "contactForm",
        ) as HTMLFormElement | null;
        const textarea = document.getElementById(
            "message",
        ) as HTMLTextAreaElement | null;
        const charCountEl = document.getElementById("charCount");
        const charCounter = document.querySelector(".char-counter");
        const submitBtn = document.getElementById(
            "submitBtn",
        ) as HTMLButtonElement | null;
        const submitLabel = document.getElementById("submitLabel");
        const submitArrow = document.getElementById("submitArrow");
        const submitSpinner = document.getElementById("submitSpinner");
        const errorNotif = document.getElementById("errorNotification");

        if (!form || !textarea) return;

        const updateCount = () => {
            const len = textarea.value.length;
            if (charCountEl) charCountEl.textContent = String(len);
            if (charCounter) {
                charCounter.classList.toggle(
                    "near-limit",
                    len > 1800 && len < 2000,
                );
                charCounter.classList.toggle("at-limit", len >= 2000);
            }
        };

        textarea.addEventListener("input", updateCount);
        updateCount();

        const showError = (msg: string) => {
            if (!errorNotif) return;
            errorNotif.textContent = msg;
            errorNotif.classList.remove("hidden");
            errorNotif.scrollIntoView({ behavior: "smooth", block: "nearest" });
            setTimeout(() => errorNotif.classList.add("hidden"), 5000);
        };

        form.addEventListener("submit", (e) => {
            const honeypot = form.querySelector<HTMLInputElement>(
                'input[name="website"]',
            );
            if (honeypot?.value.trim()) {
                e.preventDefault();
                return;
            }

            const privacy = form.querySelector<HTMLInputElement>(
                'input[name="privacy"]',
            );
            if (!privacy?.checked) {
                e.preventDefault();
                showError("Veuillez accepter la politique de confidentialité.");
                privacy?.focus();
                return;
            }

            if (textarea.value.trim().length < 20) {
                e.preventDefault();
                showError("Le message doit contenir au moins 20 caractères.");
                textarea.focus();
                return;
            }

            if (submitBtn && submitLabel && submitArrow && submitSpinner) {
                submitBtn.disabled = true;
                submitLabel.textContent = "Envoi en cours…";
                submitArrow.classList.add("hidden");
                submitSpinner.classList.remove("hidden");
            }
        });
    })();
</script>
