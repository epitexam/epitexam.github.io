---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GitHubProject from "../components/GitHubProject.astro";
import LatestPost from "../components/LatestPost.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE, GITHUB_URL } from "../consts";
import type { Project } from "../types/github";
import Avatar from "../components/Avatar.astro";

const username = SITE_TITLE.toLowerCase().replace(/\s+/g, "");
let projects: Project[] = [];

if (import.meta.env.SSR) {
	try {
		const token = import.meta.env.TOKEN_GITHUB;
		const response = await fetch(
			`https://api.github.com/users/${username}/repos?sort=pushed&per_page=6`,
			{
				headers: token ? { Authorization: `token ${token}` } : {},
				signal: AbortSignal.timeout(5000),
			},
		);
		if (response.ok) {
			projects = (await response.json()) as Project[];
		}
	} catch {
		projects = [];
	}
}

const allPosts = await getCollection("blog");
let latestPost: Awaited<ReturnType<typeof getCollection<"blog">>>[0] | null =
	null;

for (const post of allPosts) {
	if (!latestPost || post.data.pubDate > latestPost.data.pubDate) {
		latestPost = post;
	}
}
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="home-main">
			<section class="hero-v">
				<Avatar />

				<h1 class="hero-title">
					Développeur Web<br />
					<span class="title-accent">Full-Stack</span>
				</h1>

				<p class="hero-description">
					Passionné par l'embarqué, le web et les systèmes connectés.
					Je conçois des solutions performantes du frontend au
					backend.
				</p>

				<div class="cta-group">
					<a
						href={GITHUB_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="btn-pill btn-solid"
					>
						<svg
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="currentColor"
							aria-hidden="true"
						>
							<path
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
							></path>
						</svg>
						GitHub
					</a>
					<a href="/blog" class="btn-pill btn-outline"
						>Blog technique</a
					>
				</div>

				<div class="hash-list" aria-label="Technologies">
					<span>#WebDev</span>
					<span>#LowLevel</span>
					<span>#Embedded</span>
					<span>#Backend</span>
					<span>#DevOps</span>
				</div>
			</section>

			{
				latestPost && (
					<div class="blog-section">
						<LatestPost post={latestPost} />
						<div class="blog-footer">
							<a href="/blog" class="view-all-link">
								Voir tous les articles
								<svg
									class="arrow-icon"
									width="15"
									height="15"
									viewBox="0 0 16 16"
									fill="none"
									aria-hidden="true"
								>
									<path
										d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</a>
						</div>
					</div>
				)
			}

			<section class="projects-v" aria-labelledby="projects-heading">
				<div class="projects-header">
					<div class="section-badge">
						<span class="badge-dot" aria-hidden="true"></span>
						<span>Projets récents</span>
					</div>
					<h2 id="projects-heading" class="section-title">
						Mes derniers projets
					</h2>
					<p class="section-subtitle">
						Une sélection de mes projets les plus récents sur GitHub
					</p>
				</div>

				<div class="projects-grid">
					{
						projects.length > 0 ? (
							projects.map((repo) => (
								<GitHubProject project={repo} eager={false} />
							))
						) : (
							<div class="projects-fallback">
								<p>Impossible de charger les projets GitHub.</p>
								<a
									href={GITHUB_URL}
									target="_blank"
									rel="noopener noreferrer"
								>
									Voir sur GitHub directement →
								</a>
							</div>
						)
					}
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	.home-main {
		align-items: center;
		gap: 5rem;
	}

	.hero-v {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
	}

	.hero-title {
		text-align: center;
		font-size: clamp(2.2rem, 7vw, 4rem);
		line-height: 1.1;
		margin: 0 0 1.25rem;
		font-weight: 800;
		letter-spacing: -0.025em;
		animation: none;
	}

	.title-accent {
		background: linear-gradient(
			135deg,
			rgb(var(--accent)),
			rgba(var(--accent), 0.55)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-description {
		text-align: center;
		max-width: 580px;
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-muted);
		margin: 0 0 2.5rem;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.btn-pill {
		padding: 0.8rem 1.75rem;
		border-radius: 999px;
		font-family: var(--font-title);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0.02em;
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		transition:
			transform var(--duration-base) var(--ease-spring),
			box-shadow var(--duration-base) ease,
			filter var(--duration-fast) ease;
	}

	.btn-solid {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid transparent;
		box-shadow: 0 2px 12px rgba(var(--accent), 0.3);
	}

	.btn-solid:hover {
		transform: translateY(-3px);
		box-shadow: 0 6px 20px rgba(var(--accent), 0.4);
		filter: brightness(1.06);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid rgba(var(--accent), 0.3);
	}

	.btn-outline:hover {
		transform: translateY(-3px);
		border-color: rgba(var(--accent), 0.6);
		background: rgba(var(--accent), 0.06);
		box-shadow: 0 4px 14px rgba(var(--accent), 0.18);
	}

	.hash-list {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		font-family: var(--font-title);
		font-size: 0.7rem;
		letter-spacing: 0.06em;
	}

	.hash-list span {
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent), 0.05);
		border: 1px solid rgba(var(--accent), 0.12);
		color: rgba(var(--text), 0.42);
		transition:
			color var(--duration-fast) ease,
			border-color var(--duration-fast) ease,
			background var(--duration-fast) ease;
	}

	.hash-list span:hover {
		color: var(--color-accent);
		border-color: rgba(var(--accent), 0.35);
		background: rgba(var(--accent), 0.08);
	}

	.blog-section {
		width: 100%;
	}

	.blog-footer {
		width: 100%;
		display: flex;
		justify-content: center;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
	}

	.view-all-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--font-title);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: var(--color-muted);
		padding: 0.65rem 1.4rem;
		border-radius: 999px;
		border: 1px solid rgba(var(--accent), 0.15);
		background: rgba(var(--accent), 0.03);
		transition:
			color var(--duration-fast) ease,
			border-color var(--duration-fast) ease,
			background var(--duration-fast) ease,
			transform var(--duration-base) var(--ease-spring),
			box-shadow var(--duration-fast) ease;
	}

	.view-all-link:hover {
		color: var(--color-accent);
		border-color: rgba(var(--accent), 0.45);
		background: rgba(var(--accent), 0.07);
		transform: translateY(-2px);
		box-shadow: 0 4px 14px rgba(var(--accent), 0.15);
	}

	.arrow-icon {
		transition: transform var(--duration-base) var(--ease-spring);
		flex-shrink: 0;
	}

	.view-all-link:hover .arrow-icon {
		transform: translateX(4px);
	}

	.projects-v {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
	}

	.projects-header {
		text-align: center;
		margin-bottom: 2.25rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.65rem;
	}

	.section-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.4rem 1rem;
		background: rgba(var(--accent), 0.05);
		border: 1px solid rgba(var(--accent), 0.15);
		border-radius: 999px;
		font-family: var(--font-title);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-accent);
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		background: var(--color-accent);
		border-radius: 50%;
		flex-shrink: 0;
		animation: pulse 2.5s ease-in-out infinite;
	}

	@keyframes pulse {
		0%,
		100% {
			box-shadow: 0 0 4px rgba(var(--accent), 0.5);
		}
		50% {
			box-shadow: 0 0 10px rgba(var(--accent), 1);
		}
	}

	.section-title {
		font-family: var(--font-title);
		font-size: clamp(1.5rem, 4vw, 2.2rem);
		font-weight: 700;
		letter-spacing: -0.025em;
		color: var(--color-text);
		margin: 0;
		animation: none;
	}

	.section-subtitle {
		font-size: 0.95rem;
		color: var(--color-muted);
		max-width: 500px;
		line-height: 1.65;
		margin: 0;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
		width: 100%;
	}

	.projects-fallback {
		grid-column: span 2;
		padding: 3rem 2rem;
		border: 1px dashed rgba(var(--accent), 0.2);
		border-radius: var(--radius-md);
		text-align: center;
		background: rgba(var(--accent), 0.02);
	}

	.projects-fallback p {
		color: var(--color-muted);
		margin-bottom: 1rem;
	}

	.projects-fallback a {
		color: var(--color-accent);
		font-family: var(--font-title);
		font-size: 0.85rem;
		font-weight: 600;
	}

	@media (max-width: 768px) {
		.home-main {
			gap: 3.5rem;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}

		.projects-fallback {
			grid-column: span 1;
		}
	}

	@media (max-width: 480px) {
		.home-main {
			gap: 2.5rem;
		}

		.hero-title {
			font-size: 2rem;
		}

		.hero-description {
			font-size: 0.95rem;
		}

		.cta-group {
			flex-direction: column;
			width: 100%;
		}

		.btn-pill {
			justify-content: center;
		}

		.hash-list {
			gap: 0.4rem;
		}

		.hash-list span {
			font-size: 0.65rem;
			padding: 0.25rem 0.6rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.badge-dot {
			animation: none;
		}

		.btn-solid:hover,
		.btn-outline:hover,
		.view-all-link:hover {
			transform: none;
		}

		.arrow-icon {
			transition: none;
		}
	}
</style>
