---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import { SITE_TITLE } from "../../consts";
import Header from "../../components/Header.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog"))
	.filter(({ data }) => !data.draft)
	.sort((a, b) => {
		const dateA = a.data.pubDate?.getTime() ?? 0;
		const dateB = b.data.pubDate?.getTime() ?? 0;
		return dateB - dateA;
	});

const EAGER_LIMIT = 3;
const BLOG_META_DESCRIPTION =
	"Articles et réflexions sur le développement logiciel par Epitexam — architecture, performance, outillage et retours d'expérience.";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Blog",
	name: `Blog — ${SITE_TITLE}`,
	description: BLOG_META_DESCRIPTION,
	url: "https://epitexam.github.io/blog",
	author: {
		"@type": "Person",
		name: "Epitexam",
		url: "https://epitexam.github.io",
	},
	blogPost: posts.map((post) => ({
		"@type": "BlogPosting",
		headline: post.data.title,
		description: post.data.description ?? "",
		datePublished: post.data.pubDate?.toISOString(),
		...(post.data.updatedDate && {
			dateModified: post.data.updatedDate.toISOString(),
		}),
		url: `https://epitexam.github.io/blog/${post.id}/`,
		author: {
			"@type": "Person",
			name: "Epitexam",
		},
	})),
};
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`Blog - ${SITE_TITLE}`}
			description={BLOG_META_DESCRIPTION}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />

		<main class="blog-index">
			<header class="page-header">
				<h1 class="page-title">Blog</h1>
			</header>

			<section aria-labelledby="blog-list-heading">
				<h2 id="blog-list-heading" class="sr-only">
					Liste des articles
				</h2>

				<ul class="blog-grid" role="list">
					{
						posts.map((post, index) => {
							const isEager = index < EAGER_LIMIT;
							const isFeatured = index === 0;
							const pubDatetime =
								post.data.pubDate?.toISOString() ?? "";

							return (
								<li
									class:list={[
										"blog-item",
										{ featured: isFeatured },
									]}
								>
									<a
										href={`/blog/${post.id}/`}
										class="blog-card"
										aria-label={`Lire l'article : ${post.data.title}`}
									>
										<div
											class="card-glow"
											aria-hidden="true"
										/>

										{post.data.heroImage && (
											<div class="image-container">
												<Image
													src={post.data.heroImage}
													alt={
														post.data
															.heroImageDescription ||
														post.data.title
													}
													class="card-img"
													loading={
														isEager
															? "eager"
															: "lazy"
													}
													fetchpriority={
														isFeatured
															? "high"
															: "auto"
													}
													decoding={
														isFeatured
															? "sync"
															: "async"
													}
													widths={
														isFeatured
															? [
																	480, 700,
																	960, 1280,
																]
															: [
																	320, 480,
																	662, 960,
																]
													}
													sizes={
														isFeatured
															? "(max-width: 768px) 100vw, 520px"
															: "(max-width: 540px) 100vw, (max-width: 768px) 50vw, 480px"
													}
												/>
											</div>
										)}

										<div class="card-body">
											<time
												class="card-date"
												datetime={pubDatetime}
											>
												<FormattedDate
													date={post.data.pubDate}
												/>
											</time>

											<h2 class="card-title">
												{post.data.title}
											</h2>

											{post.data.description && (
												<p class="card-description">
													{post.data.description}
												</p>
											)}

											<span
												class="read-more"
												aria-hidden="true"
											>
												Lire l'article
												<svg
													class="arrow-icon"
													width="14"
													height="14"
													viewBox="0 0 16 16"
													fill="none"
													aria-hidden="true"
												>
													<path
														d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
														stroke="currentColor"
														stroke-width="1.5"
														stroke-linecap="round"
														stroke-linejoin="round"
													/>
												</svg>
											</span>
										</div>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	.blog-index {
		flex-grow: 1;
		width: 100%;
		max-width: var(--max-width);
		margin-inline: auto;
		padding-block-start: calc(var(--header-height) + 3rem);
		padding-block-end: 4rem;
		padding-inline: var(--content-padding);
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.blog-index :is(h1, h2, h3, h4, h5, h6) {
		animation: none;
	}

	.blog-index ul,
	.blog-index ol {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.page-header {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.page-title {
		font-size: clamp(2.25rem, 6vw, 3.5rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.04em;
		margin: 0;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		width: 100%;
	}

	.blog-item {
		display: flex;
	}

	.blog-item.featured {
		grid-column: 1 / -1;
	}

	a.blog-card {
		position: relative;
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
		color: inherit;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		isolation: isolate;
		box-shadow: var(--shadow-soft);
		transition:
			transform var(--duration-base) var(--ease-spring),
			border-color var(--duration-base) var(--ease-spring),
			box-shadow var(--duration-base) var(--ease-spring);
	}

	@media (hover: hover) {
		a.blog-card:hover {
			transform: translateY(-2px);
			border-color: rgba(var(--accent), 0.2);
			box-shadow: var(--shadow-strong);
		}

		a.blog-card:hover .card-glow {
			opacity: 1;
		}
		a.blog-card:hover .card-img {
			transform: scale(1.04);
			filter: brightness(1) contrast(1.1) saturate(1.05);
		}
		a.blog-card:hover .card-title {
			color: var(--color-accent);
		}
		a.blog-card:hover .read-more::after {
			transform: scaleX(1);
		}
		a.blog-card:hover .arrow-icon {
			transform: translateX(4px);
		}
	}

	.blog-item.featured a.blog-card {
		flex-direction: row;
	}

	.blog-item.featured .image-container {
		width: 50%;
		flex-shrink: 0;
		aspect-ratio: unset;
		min-height: 280px;
		border-right: 1px solid var(--color-border);
	}

	.blog-item.featured .card-body {
		padding: 2.5rem;
		justify-content: center;
	}

	.blog-item.featured .card-title {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
	}

	.blog-item.featured .card-description {
		-webkit-line-clamp: 4;
	}

	.card-glow {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: radial-gradient(
			ellipse at 50% 0%,
			rgba(var(--accent), 0.08) 0%,
			transparent 60%
		);
		opacity: 0;
		z-index: 0;
		pointer-events: none;
		transition: opacity var(--duration-base) ease;
	}

	.image-container {
		aspect-ratio: 16 / 9;
		width: 100%;
		overflow: hidden;
		flex-shrink: 0;
		position: relative;
		z-index: 1;
	}

	.card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: brightness(0.9) contrast(1.05) saturate(0.95);
		transition:
			transform var(--duration-slow) var(--ease-spring),
			filter var(--duration-slow) ease;
	}

	.card-body {
		position: relative;
		z-index: 2;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.card-date {
		display: block;
		font-family: var(--font-title);
		font-size: 0.8rem;
		color: var(--color-muted);
		margin: 0 0 0.75rem;
		letter-spacing: -0.01em;
	}

	.card-title {
		font-family: var(--font-title);
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 0.75rem;
		padding: 0;
		transition: color var(--duration-fast) ease;
	}

	.card-description {
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--color-muted);
		margin: 0 0 1.5rem;
		flex-grow: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color var(--duration-fast) ease;
	}

	.read-more {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-accent);
		font-family: var(--font-title);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin-top: auto;
		width: fit-content;
		position: relative;
		padding-bottom: 2px;
	}

	.read-more::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--color-accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--duration-base) var(--ease-spring);
	}

	.arrow-icon {
		transition: transform var(--duration-base) var(--ease-spring);
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.blog-index {
			padding-block-start: calc(var(--header-height) + 2rem);
			padding-block-end: 3rem;
			padding-inline: var(--content-padding-mobile);
		}

		.blog-item.featured a.blog-card {
			flex-direction: column;
		}

		.blog-item.featured .image-container {
			width: 100%;
			aspect-ratio: 16 / 9;
			min-height: unset;
			border-right: none;
			border-bottom: 1px solid var(--color-border);
		}

		.blog-item.featured .card-body {
			padding: 1.5rem;
		}

		.blog-item.featured .card-title {
			font-size: 1.4rem;
		}
	}

	@media (max-width: 540px) {
		.blog-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		a.blog-card:hover,
		a.blog-card:hover .card-img,
		a.blog-card:hover .arrow-icon {
			transform: none;
		}
	}
</style>
